<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="16.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ServerPortFrameController">
   <padding>
      <Insets bottom="24.0" left="24.0" right="24.0" top="20.0" />
   </padding>

   <HBox alignment="CENTER_LEFT">
      <Label styleClass="title-label" text="Server Control Panel">
         <font><Font name="Segoe UI Light" size="22.0" /></font>
      </Label>
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
   </HBox>

   <VBox spacing="14.0" styleClass="card" style="-fx-padding: 18;">
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <Label styleClass="body-label" text="Status:">
            <font><Font name="Segoe UI" size="13.0" /></font>
         </Label>
         <Label fx:id="statusIndicator" style="-fx-text-fill: #ef5350; -fx-font-weight: bold;" text="OFFLINE">
            <font><Font name="Segoe UI" size="13.0" /></font>
         </Label>
         <Region HBox.hgrow="ALWAYS" />
         
         <Label styleClass="subtitle-label" text="Port:">
            <font><Font name="Segoe UI" size="13.0" /></font>
         </Label>
         <TextField fx:id="portField" prefWidth="70.0" text="5555" style="-fx-font-size: 13px; -fx-padding: 6 10;" />
         
         <PasswordField fx:id="dbPassField" promptText="DB Password" prefWidth="120.0" style="-fx-font-size: 13px; -fx-padding: 6 10;" />
         
         <Button fx:id="startBtn" mnemonicParsing="false" onAction="#startServer" styleClass="success-btn" style="-fx-font-size: 13px; -fx-padding: 7 18;" text="Start" />
         <Button fx:id="stopBtn" mnemonicParsing="false" onAction="#stopServer" styleClass="danger-btn" style="-fx-font-size: 13px; -fx-padding: 7 18;" text="Stop" />
      </HBox>
   </VBox>

   <HBox spacing="16.0" VBox.vgrow="ALWAYS">

      <VBox spacing="10.0" styleClass="card" style="-fx-padding: 16;" HBox.hgrow="ALWAYS" prefWidth="350.0">
         <Label styleClass="subtitle-label" text="CONNECTED CLIENTS">
            <font><Font name="Segoe UI" size="11.0" /></font>
         </Label>
         <TableView fx:id="clientsTable" VBox.vgrow="ALWAYS">
           <columns>
             <TableColumn fx:id="ipCol" prefWidth="105.0" text="IP Address" />
             <TableColumn fx:id="hostCol" prefWidth="100.0" text="Host" />
             <TableColumn fx:id="userCol" prefWidth="120.0" text="Username" />
             <TableColumn fx:id="roleCol" prefWidth="100.0" text="Role" />
             <TableColumn fx:id="statusCol" prefWidth="75.0" text="Status" />
           </columns>
            <columnResizePolicy>
               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
         </TableView>
      </VBox>

      <VBox spacing="10.0" styleClass="card" style="-fx-padding: 16;" HBox.hgrow="ALWAYS" prefWidth="350.0">
         <HBox alignment="CENTER_LEFT">
            <Label styleClass="subtitle-label" text="SYSTEM LOGS">
               <font><Font name="Segoe UI" size="11.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#clearLogs" styleClass="secondary-btn" style="-fx-font-size: 11px; -fx-padding: 4 10;" text="Clear" />
         </HBox>
         <TextArea fx:id="consoleText" editable="false" wrapText="true" VBox.vgrow="ALWAYS" styleClass="console-area" />
      </VBox>

   </HBox>
</VBox>