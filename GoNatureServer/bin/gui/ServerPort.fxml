<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ServerPortFrameController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>

   <Label style="-fx-text-fill: #2d3436;" text="Server Control Panel">
      <font>
         <Font name="Segoe UI Bold" size="24.0" />
      </font>
   </Label>

   <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </padding>
      <HBox alignment="CENTER_LEFT" spacing="5.0">
         <Label text="Current Status: ">
            <font>
               <Font name="Segoe UI" size="16.0" />
            </font>
         </Label>
         <Label fx:id="statusIndicator" style="-fx-text-fill: #d63031;" text="OFFLINE">
            <font>
               <Font name="Segoe UI Bold" size="16.0" />
            </font>
         </Label>
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <Label style="-fx-font-weight: bold; -fx-text-fill: #2d3436;" text="Listen Port:" />
         <TextField fx:id="portField" prefWidth="80.0" text="5555" editable="false" disable="true" />
         <Button fx:id="startBtn" mnemonicParsing="false" onAction="#startServer" text="Start Server" />
         <Button fx:id="stopBtn" mnemonicParsing="false" onAction="#stopServer" text="Stop Server" />
      </HBox>
   </VBox>

   <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" VBox.vgrow="ALWAYS">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <HBox alignment="CENTER_LEFT">
         <Label text="System Logs">
            <font>
               <Font name="Segoe UI Bold" size="14.0" />
            </font>
         </Label>
         <Region HBox.hgrow="ALWAYS" />
         <Button mnemonicParsing="false" onAction="#clearLogs" style="-fx-background-color: #dfe6e9; -fx-text-fill: #2d3436; -fx-font-size: 11px; -fx-cursor: hand;" text="Clear Logs" />
      </HBox>
      <TextArea fx:id="consoleText" editable="false" style="-fx-control-inner-background: #2d3436; -fx-background-color: transparent; -fx-text-fill: #55efc4; -fx-font-family: 'Consolas'; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-padding: 5;" wrapText="true" VBox.vgrow="ALWAYS" />
   </VBox>
</VBox>