<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="850.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.guest.GuestPortalController">
   <top>
      <BorderPane BorderPane.alignment="CENTER">
         <padding><Insets bottom="10.0" left="20.0" right="20.0" top="15.0" /></padding>
         <left>
            <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleGoBack" styleClass="back-link" text="&lt; Back to Main Menu" />
         </left>
         <right>
            <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
         </right>
      </BorderPane>
   </top>
   <center>
      <VBox alignment="TOP_CENTER" spacing="20.0" maxWidth="780.0">
         <BorderPane.margin><Insets bottom="30.0" /></BorderPane.margin>
         
         <HBox alignment="CENTER" spacing="15.0" styleClass="card">
            <padding><Insets bottom="18.0" left="25.0" right="25.0" top="18.0" /></padding>
            <Label styleClass="title-label" text="Manage Orders"><font><Font name="Segoe UI Bold" size="20.0" /></font></Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label styleClass="body-label" text="Visitor ID:"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
            <TextField fx:id="txtVisitorId" prefWidth="180.0" promptText="Enter ID" />
            <Button mnemonicParsing="false" onAction="#handleFindOrders" styleClass="primary-btn" style="-fx-font-weight: bold; -fx-padding: 8 20;" text="🔍 Find Orders" />
         </HBox>
         
         <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10.0">
            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
            <Label styleClass="section-blue" text="Your Bookings"><font><Font name="Segoe UI Bold" size="15.0" /></font></Label>
            <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colOrderId" prefWidth="90.0" text="Order ID" />
                <TableColumn fx:id="colParkId" prefWidth="90.0" text="Park ID" />
                <TableColumn fx:id="colDate" prefWidth="130.0" text="Date" />
                <TableColumn fx:id="colTime" prefWidth="100.0" text="Time" />
                <TableColumn fx:id="colVisitors" prefWidth="90.0" text="Visitors" />
                <TableColumn fx:id="colStatus" prefWidth="180.0" text="Status" />
              </columns>
              <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
         </VBox>
         
         <VBox alignment="CENTER" spacing="10.0" styleClass="card">
            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
            <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity" wrapText="true" />
            <HBox alignment="CENTER" spacing="25.0">
               <Button fx:id="btnConfirmOrder" mnemonicParsing="false" onAction="#handleConfirmOrder" prefHeight="45.0" prefWidth="250.0" styleClass="success-btn" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="✅ Confirm Selected Order" />
               <Button fx:id="btnCancelOrder" mnemonicParsing="false" onAction="#handleCancelOrder" prefHeight="45.0" prefWidth="250.0" styleClass="danger-btn" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="❌ Cancel Selected Order" />
            </HBox>
         </VBox>
         
      </VBox>
   </center>
</BorderPane>