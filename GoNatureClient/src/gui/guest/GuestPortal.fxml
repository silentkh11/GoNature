<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="840.0" prefWidth="900.0" styleClass="page-root"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.guest.GuestPortalController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <padding><Insets bottom="10.0" left="24.0" right="24.0" top="18.0" /></padding>
         <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleGoBack"
                 styleClass="back-link" text="← Back to Main Menu" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false"
                 onAction="#handleToggleTheme" styleClass="theme-toggle" text="☀ Light Mode" />
      </HBox>
   </top>

   <center>
      <ScrollPane fitToWidth="true" styleClass="page-root">
         <content>
            <VBox alignment="TOP_CENTER" spacing="18.0">
               <padding><Insets bottom="30.0" left="28.0" right="28.0" top="10.0" /></padding>

               <!-- Page Title -->
               <HBox alignment="CENTER_LEFT" spacing="12.0">
                  <VBox.margin><Insets bottom="4.0" /></VBox.margin>
                  <Label text="📁" style="-fx-font-size: 22px;" />
                  <VBox spacing="2.0">
                     <Label text="My Bookings" styleClass="title-label"
                            style="-fx-font-size: 22px; -fx-font-weight: bold;" />
                     <Label text="Look up and manage your GoNature reservations"
                            styleClass="subtitle-label" style="-fx-font-size: 12px;" />
                  </VBox>
               </HBox>

               <!-- Search Bar -->
               <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="card"
                     style="-fx-padding: 16 22;">
                  <Label styleClass="body-label" text="Visitor ID"
                         style="-fx-font-size: 13px; -fx-font-weight: bold;" />
                  <TextField fx:id="txtVisitorId" prefWidth="200.0" promptText="Enter your ID number"
                             style="-fx-font-size: 14px; -fx-padding: 9 12;" />
                  <Button mnemonicParsing="false" onAction="#handleFindOrders"
                          styleClass="primary-btn"
                          style="-fx-font-weight: bold; -fx-padding: 9 22; -fx-font-size: 13px;"
                          text="🔍  Find My Orders" />
                  <Region HBox.hgrow="ALWAYS" />
               </HBox>

               <!-- Orders Table -->
               <VBox styleClass="card" spacing="12.0">
                  <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>

                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <Label text="🗃" style="-fx-font-size: 15px;" />
                     <Label styleClass="section-blue" text="Your Reservations"
                            style="-fx-font-size: 14px;" />
                  </HBox>

                  <TableView fx:id="ordersTable" prefHeight="200.0">
                     <columns>
                        <TableColumn fx:id="colOrderId"  prefWidth="85.0"  text="Order ID" />
                        <TableColumn fx:id="colParkId"   prefWidth="70.0"  text="Park" />
                        <TableColumn fx:id="colDate"     prefWidth="120.0" text="Date" />
                        <TableColumn fx:id="colTime"     prefWidth="85.0"  text="Time" />
                        <TableColumn fx:id="colVisitors" prefWidth="75.0"  text="Visitors" />
                        <TableColumn fx:id="colType"     prefWidth="95.0"  text="Type" />
                        <TableColumn fx:id="colStatus"   prefWidth="165.0" text="Status" />
                     </columns>
                     <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                  </TableView>

                  <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity"
                         wrapText="true" style="-fx-font-size: 12.5px;" />
               </VBox>

               <!-- SUBSCRIBER PROFILE PANEL -->
               <VBox fx:id="pnlSubscriberProfile" styleClass="card" spacing="16.0"
                     visible="false" managed="false"
                     style="-fx-border-color: rgba(76,158,232,0.16) rgba(76,158,232,0.16) rgba(76,158,232,0.16) rgba(76,158,232,0.70); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 14 14 0; -fx-background-radius: 0 14 14 0;">
                  <padding><Insets bottom="24.0" left="26.0" right="26.0" top="22.0" /></padding>

                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <Label text="👤" style="-fx-font-size: 16px;" />
                     <Label styleClass="section-blue" text="Subscriber Profile"
                            style="-fx-font-size: 15px;" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Label fx:id="lblSubId"
                            style="-fx-text-fill: #4C9EE8; -fx-font-weight: bold; -fx-font-size: 13px;" />
                  </HBox>
                  <Separator style="-fx-opacity: 0.5;" />

                  <GridPane hgap="20.0" vgap="14.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="130.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="130.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                     </columnConstraints>

                     <Label text="First Name" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="0" GridPane.rowIndex="0" />
                     <TextField fx:id="subFirstName" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity" />

                     <Label text="Last Name" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="2" GridPane.rowIndex="0" />
                     <TextField fx:id="subLastName" GridPane.columnIndex="3" GridPane.rowIndex="0" maxWidth="Infinity" />

                     <Label text="Email" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="0" GridPane.rowIndex="1" />
                     <TextField fx:id="subEmail" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" />

                     <Label text="Phone" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="2" GridPane.rowIndex="1" />
                     <TextField fx:id="subPhone" GridPane.columnIndex="3" GridPane.rowIndex="1" maxWidth="Infinity" />

                     <Label text="Family Size" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="0" GridPane.rowIndex="2" />
                     <TextField fx:id="subFamilySize" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity" />

                     <Label text="Guide Status" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="2" GridPane.rowIndex="2" />
                     <Label fx:id="lblSubGuide"
                            style="-fx-font-size: 13px; -fx-font-weight: bold;"
                            GridPane.columnIndex="3" GridPane.rowIndex="2" />
                  </GridPane>

                  <Separator style="-fx-opacity: 0.5;" />
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <Button mnemonicParsing="false" onAction="#handleSaveSubscriberProfile"
                             prefHeight="40.0" prefWidth="230.0"
                             styleClass="success-btn"
                             style="-fx-font-weight: bold; -fx-font-size: 13px;"
                             text="💾  Save Profile Changes" />
                  </HBox>
               </VBox>

               <!-- EDIT PANEL (Booked / Waitlisted) -->
               <VBox fx:id="pnlEdit" styleClass="card" spacing="16.0"
                     visible="false" managed="false"
                     style="-fx-border-color: rgba(232,160,32,0.16) rgba(232,160,32,0.16) rgba(232,160,32,0.16) rgba(232,160,32,0.70); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 14 14 0; -fx-background-radius: 0 14 14 0;">
                  <padding><Insets bottom="24.0" left="26.0" right="26.0" top="22.0" /></padding>

                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <Label text="✏" style="-fx-font-size: 15px;" />
                     <Label styleClass="section-blue" text="Edit Booking"
                            style="-fx-font-size: 15px;" />
                     <Label fx:id="lblEditStatus"
                            style="-fx-text-fill: #E8A020; -fx-font-size: 13px; -fx-font-weight: bold;" />
                  </HBox>
                  <Separator style="-fx-opacity: 0.5;" />

                  <GridPane hgap="20.0" vgap="14.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                     </columnConstraints>

                     <Label styleClass="body-label" text="Visit Date"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="0" GridPane.rowIndex="0" />
                     <DatePicker fx:id="editDate" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity" />

                     <Label styleClass="body-label" text="Visit Time"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="2" GridPane.rowIndex="0" />
                     <ComboBox fx:id="editTime" GridPane.columnIndex="3" GridPane.rowIndex="0" maxWidth="Infinity" />

                     <Label styleClass="body-label" text="Visitor Count"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="0" GridPane.rowIndex="1" />
                     <TextField fx:id="editCount" promptText="Number of visitors"
                                GridPane.columnIndex="1" GridPane.rowIndex="1" />

                     <Label styleClass="body-label" text="Current Price"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;"
                            GridPane.columnIndex="2" GridPane.rowIndex="1" />
                     <Label fx:id="lblCurrentPrice"
                            style="-fx-text-fill: #1DC98A; -fx-font-weight: bold; -fx-font-size: 15px;"
                            GridPane.columnIndex="3" GridPane.rowIndex="1" />
                  </GridPane>

                  <Separator style="-fx-opacity: 0.5;" />
                  <HBox alignment="CENTER_RIGHT" spacing="14.0">
                     <Button mnemonicParsing="false" onAction="#handleCancelOrder"
                             prefHeight="40.0" prefWidth="185.0" styleClass="danger-btn"
                             style="-fx-font-weight: bold;" text="❌  Cancel Booking" />
                     <Button mnemonicParsing="false" onAction="#handleSaveEdit"
                             prefHeight="40.0" prefWidth="195.0" styleClass="success-btn"
                             style="-fx-font-weight: bold;" text="💾  Save Changes" />
                  </HBox>
               </VBox>

               <!-- CONFIRM PANEL (Pending Confirm / Waitlist Pending) -->
               <VBox fx:id="pnlConfirm" styleClass="card" spacing="16.0"
                     visible="false" managed="false"
                     style="-fx-border-color: rgba(21,138,94,0.16) rgba(21,138,94,0.16) rgba(21,138,94,0.16) rgba(21,138,94,0.80); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 14 14 0; -fx-background-radius: 0 14 14 0;">
                  <padding><Insets bottom="24.0" left="26.0" right="26.0" top="22.0" /></padding>

                  <Label fx:id="lblConfirmHeading" styleClass="section-blue"
                         style="-fx-font-size: 15px;" />
                  <Separator style="-fx-opacity: 0.5;" />

                  <Label fx:id="lblConfirmDetail" wrapText="true" maxWidth="Infinity"
                         style="-fx-text-fill: #E8A020; -fx-font-size: 13px; -fx-line-spacing: 3;" />

                  <HBox alignment="CENTER" spacing="20.0">
                     <VBox.margin><Insets top="6.0" /></VBox.margin>
                     <Button mnemonicParsing="false" onAction="#handleConfirmOrder"
                             prefHeight="48.0" prefWidth="240.0"
                             styleClass="success-btn"
                             style="-fx-font-size: 14px; -fx-font-weight: bold;"
                             text="✅  Confirm My Attendance" />
                     <Button mnemonicParsing="false" onAction="#handleCancelOrder"
                             prefHeight="48.0" prefWidth="195.0"
                             styleClass="danger-btn"
                             style="-fx-font-size: 13px; -fx-font-weight: bold;"
                             text="❌  Cancel Booking" />
                  </HBox>
               </VBox>

               <!-- READ-ONLY PANEL (Confirmed / In Park / Completed / Cancelled) -->
               <VBox fx:id="pnlReadOnly" styleClass="card" spacing="14.0"
                     visible="false" managed="false">
                  <padding><Insets bottom="20.0" left="26.0" right="26.0" top="18.0" /></padding>
                  <Label fx:id="lblReadOnlyStatus" maxWidth="Infinity" wrapText="true"
                         style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                  <Button fx:id="btnReadOnlyCancel" mnemonicParsing="false"
                          onAction="#handleCancelOrder"
                          prefHeight="40.0" prefWidth="200.0" styleClass="danger-btn"
                          style="-fx-font-weight: bold;" text="❌  Cancel Booking"
                          visible="false" managed="false" />
               </VBox>

            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
