<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="850.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.guest.GuestPortalController">

   <top>
      <BorderPane BorderPane.alignment="CENTER">
         <padding><Insets left="20.0" right="20.0" top="15.0" bottom="5.0" /></padding>
         <left>
            <Button mnemonicParsing="false" onAction="#handleGoBack" styleClass="back-link" text="&lt; Back to Main Menu" />
         </left>
         <right>
            <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
         </right>
      </BorderPane>
   </top>

   <center>
      <VBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <padding><Insets bottom="30.0" left="50.0" right="50.0" top="10.0" /></padding>

         <Label styleClass="title-label" text="Guest Portal &amp; Order Management">
            <font><Font name="Segoe UI Bold" size="28.0" /></font>
         </Label>

         <VBox alignment="CENTER" spacing="15.0" styleClass="card" style="-fx-padding: 20;">
            <HBox alignment="CENTER" spacing="15.0">
               <Label styleClass="body-label" text="Visitor ID:">
                  <font><Font name="Segoe UI Bold" size="16.0" /></font>
               </Label>
               <TextField fx:id="txtVisitorId" prefWidth="200.0" promptText="Your ID" style="-fx-font-size: 14px;" />
               <Button mnemonicParsing="false" onAction="#handleSearch" styleClass="primary-btn" style="-fx-font-size: 14px; -fx-padding: 8 14;" text="Find Orders" />
            </HBox>

            <TableView fx:id="ordersTable" prefHeight="300.0" prefWidth="750.0">
              <columns>
                <TableColumn fx:id="colOrderId" prefWidth="100.0" text="Order ID" />
                <TableColumn fx:id="colParkId" prefWidth="100.0" text="Park ID" />
                <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" />
                <TableColumn fx:id="colTime" prefWidth="100.0" text="Time" />
                <TableColumn fx:id="colVisitors" prefWidth="100.0" text="Visitors" />
                <TableColumn fx:id="colStatus" prefWidth="180.0" text="Status" />
              </columns>
            </TableView>

            <HBox alignment="CENTER" spacing="20.0">
               <Button fx:id="btnConfirmOrder" mnemonicParsing="false" onAction="#handleConfirmOrder" prefHeight="40.0" prefWidth="250.0" styleClass="success-btn" style="-fx-font-size: 14px;" text="Confirm Selected Order" />
               <Button fx:id="btnCancelOrder" mnemonicParsing="false" onAction="#handleCancelOrder" prefHeight="40.0" prefWidth="250.0" styleClass="danger-btn" style="-fx-font-size: 14px;" text="Cancel Selected Order" />
            </HBox>
         </VBox>

         <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity">
            <font><Font name="Segoe UI Bold" size="14.0" /></font>
         </Label>
      </VBox>
   </center>
</BorderPane>