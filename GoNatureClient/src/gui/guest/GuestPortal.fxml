<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="820.0" prefWidth="900.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.guest.GuestPortalController">
   <top>
      <BorderPane BorderPane.alignment="CENTER">
         <padding><Insets bottom="10.0" left="20.0" right="20.0" top="15.0" /></padding>
         <left>
            <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleGoBack" styleClass="back-link" text="&lt; Back to Main Menu" />
         </left>
         <right>
            <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
         </right>
      </BorderPane>
   </top>

   <center>
      <ScrollPane fitToWidth="true" styleClass="page-root">
         <content>
            <VBox alignment="TOP_CENTER" spacing="18.0" maxWidth="840.0">
               <BorderPane.margin><Insets bottom="30.0" /></BorderPane.margin>
               <padding><Insets bottom="20.0" left="20.0" right="20.0" top="10.0" /></padding>

               <!-- Search Bar -->
               <HBox alignment="CENTER" spacing="15.0" styleClass="card">
                  <padding><Insets bottom="16.0" left="25.0" right="25.0" top="16.0" /></padding>
                  <Label styleClass="title-label" text="My Bookings"><font><Font name="Segoe UI Bold" size="20.0" /></font></Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="body-label" text="Visitor ID:"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtVisitorId" prefWidth="180.0" promptText="Enter ID" />
                  <Button mnemonicParsing="false" onAction="#handleFindOrders" styleClass="primary-btn" style="-fx-font-weight: bold; -fx-padding: 8 20;" text="🔍 Find Orders" />
               </HBox>

               <!-- Orders Table -->
               <VBox styleClass="card" spacing="10.0">
                  <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0" /></padding>
                  <Label styleClass="section-blue" text="Your Bookings"><font><Font name="Segoe UI Bold" size="15.0" /></font></Label>
                  <TableView fx:id="ordersTable" prefHeight="200.0">
                    <columns>
                      <TableColumn fx:id="colOrderId"  prefWidth="80.0"  text="Order ID" />
                      <TableColumn fx:id="colParkId"   prefWidth="70.0"  text="Park" />
                      <TableColumn fx:id="colDate"     prefWidth="120.0" text="Date" />
                      <TableColumn fx:id="colTime"     prefWidth="85.0"  text="Time" />
                      <TableColumn fx:id="colVisitors" prefWidth="75.0"  text="Visitors" />
                      <TableColumn fx:id="colType"     prefWidth="95.0"  text="Type" />
                      <TableColumn fx:id="colStatus"   prefWidth="165.0" text="Status" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                  </TableView>
                  <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity" wrapText="true" />
               </VBox>

               <!-- ===== EDIT PANEL — shown for Confirmed / Waitlisted ===== -->
               <VBox fx:id="pnlEdit" styleClass="card" spacing="16.0" visible="false" managed="false">
                  <padding><Insets bottom="24.0" left="28.0" right="28.0" top="22.0" /></padding>

                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <Label styleClass="section-blue" text="Edit Booking"><font><Font name="Segoe UI Bold" size="17.0" /></font></Label>
                     <Label fx:id="lblEditStatus" style="-fx-text-fill: #f39c12; -fx-font-size: 13px; -fx-font-weight: bold;" />
                  </HBox>
                  <Separator />

                  <GridPane hgap="20.0" vgap="14.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                     </columnConstraints>

                     <Label styleClass="body-label" text="Visit Date:" GridPane.columnIndex="0" GridPane.rowIndex="0"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
                     <DatePicker fx:id="editDate" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity" />

                     <Label styleClass="body-label" text="Visit Time:" GridPane.columnIndex="2" GridPane.rowIndex="0"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
                     <ComboBox fx:id="editTime" GridPane.columnIndex="3" GridPane.rowIndex="0" maxWidth="Infinity" />

                     <Label styleClass="body-label" text="Visitor Count:" GridPane.columnIndex="0" GridPane.rowIndex="1"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
                     <TextField fx:id="editCount" promptText="Number of visitors" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                     <Label styleClass="body-label" text="Current Price:" GridPane.columnIndex="2" GridPane.rowIndex="1"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
                     <Label fx:id="lblCurrentPrice" style="-fx-text-fill: #00b894; -fx-font-weight: bold; -fx-font-size: 14px;" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                  </GridPane>

                  <Separator />
                  <HBox alignment="CENTER_RIGHT" spacing="15.0">
                     <Button mnemonicParsing="false" onAction="#handleCancelOrder" prefHeight="40.0" prefWidth="190.0" styleClass="danger-btn" style="-fx-font-weight: bold;" text="❌ Cancel Booking" />
                     <Button mnemonicParsing="false" onAction="#handleSaveEdit" prefHeight="40.0" prefWidth="210.0" styleClass="success-btn" style="-fx-font-weight: bold;" text="💾 Save Changes" />
                  </HBox>
               </VBox>

               <!-- ===== CONFIRM PANEL — shown for Pending Confirm / Waitlist Pending ===== -->
               <VBox fx:id="pnlConfirm" styleClass="card" spacing="16.0" visible="false" managed="false">
                  <padding><Insets bottom="24.0" left="28.0" right="28.0" top="22.0" /></padding>

                  <Label fx:id="lblConfirmHeading" styleClass="section-blue"><font><Font name="Segoe UI Bold" size="17.0" /></font></Label>
                  <Separator />

                  <Label fx:id="lblConfirmDetail" wrapText="true" maxWidth="Infinity"
                         style="-fx-text-fill: #f39c12; -fx-font-size: 13px;" />

                  <HBox alignment="CENTER" spacing="20.0">
                     <Button mnemonicParsing="false" onAction="#handleConfirmOrder" prefHeight="48.0" prefWidth="240.0"
                             styleClass="success-btn" style="-fx-font-size: 15px; -fx-font-weight: bold;" text="✅ Confirm My Attendance" />
                     <Button mnemonicParsing="false" onAction="#handleCancelOrder" prefHeight="48.0" prefWidth="200.0"
                             styleClass="danger-btn" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="❌ Cancel Booking" />
                  </HBox>
               </VBox>

               <!-- ===== READ-ONLY PANEL — Confirmed (cancel-only) / In Park / Completed / Cancelled ===== -->
               <VBox fx:id="pnlReadOnly" styleClass="card" spacing="14.0" visible="false" managed="false">
                  <padding><Insets bottom="20.0" left="28.0" right="28.0" top="18.0" /></padding>
                  <Label fx:id="lblReadOnlyStatus" maxWidth="Infinity" wrapText="true"
                         style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                  <Button fx:id="btnReadOnlyCancel" mnemonicParsing="false" onAction="#handleCancelOrder"
                          prefHeight="40.0" prefWidth="200.0" styleClass="danger-btn"
                          style="-fx-font-weight: bold;" text="❌ Cancel Booking"
                          visible="false" managed="false" />
               </VBox>

            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
