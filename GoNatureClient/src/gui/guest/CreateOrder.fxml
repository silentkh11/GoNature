<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="880.0" styleClass="page-root"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.guest.CreateOrderController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <padding><Insets bottom="10.0" left="24.0" right="24.0" top="18.0" /></padding>
         <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleGoBack"
                 styleClass="back-link" text="← Back to Main Menu" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false"
                 onAction="#handleToggleTheme" styleClass="theme-toggle" text="☀ Light Mode" />
      </HBox>
   </top>

   <center>
      <HBox spacing="22.0" alignment="CENTER" maxWidth="840.0">
         <BorderPane.margin><Insets bottom="30.0" left="20.0" right="20.0" /></BorderPane.margin>

         <!-- LEFT: Booking Form -->
         <VBox spacing="0" styleClass="card" HBox.hgrow="ALWAYS" maxWidth="490.0"
               style="-fx-border-color: rgba(76,158,232,0.14) rgba(76,158,232,0.14) rgba(76,158,232,0.14) rgba(29,201,138,0.60); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 14 14 0; -fx-background-radius: 0 14 14 0;">
            <padding><Insets bottom="28.0" left="28.0" right="28.0" top="24.0" /></padding>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <VBox.margin><Insets bottom="16.0" /></VBox.margin>
               <Label text="🗓" style="-fx-font-size: 20px;" />
               <VBox spacing="2.0">
                  <Label text="Plan Your Visit" styleClass="title-label"
                         style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                  <Label text="Fill in the details below to book your spot"
                         styleClass="subtitle-label" style="-fx-font-size: 12px;" />
               </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.5;">
               <VBox.margin><Insets bottom="18.0" /></VBox.margin>
            </Separator>

            <GridPane hgap="14.0" vgap="14.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0" prefWidth="105.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
               </columnConstraints>

               <Label styleClass="body-label" text="Park" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="0" />
               <ComboBox fx:id="parkCombo" maxWidth="Infinity" promptText="Choose a park…"
                         GridPane.columnIndex="1" GridPane.rowIndex="0" />

               <Label styleClass="body-label" text="Visitor ID" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="1" />
               <TextField fx:id="visitorIdField" promptText="Your ID number"
                          GridPane.columnIndex="1" GridPane.rowIndex="1" />

               <Label styleClass="body-label" text="Email" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="2" />
               <TextField fx:id="emailField" promptText="example@mail.com"
                          GridPane.columnIndex="1" GridPane.rowIndex="2" />

               <Label styleClass="body-label" text="Phone" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="3" />
               <TextField fx:id="phoneField" promptText="05X-XXXXXXX"
                          GridPane.columnIndex="1" GridPane.rowIndex="3" />

               <Label styleClass="body-label" text="Visit Date" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="4" />
               <DatePicker fx:id="datePicker" maxWidth="Infinity" promptText="Select date"
                           GridPane.columnIndex="1" GridPane.rowIndex="4" />

               <Label styleClass="body-label" text="Visit Time" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="5" />
               <ComboBox fx:id="timeCombo" maxWidth="Infinity" promptText="Select time slot"
                         GridPane.columnIndex="1" GridPane.rowIndex="5" />

               <Label styleClass="body-label" text="Visitors" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="6" />
               <TextField fx:id="visitorsField" promptText="1 – 15 people"
                          GridPane.columnIndex="1" GridPane.rowIndex="6" />

               <Label styleClass="body-label" text="Visit Type" style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.rowIndex="7" />
               <ComboBox fx:id="typeCombo" maxWidth="Infinity" promptText="Personal / Group / Guide"
                         GridPane.columnIndex="1" GridPane.rowIndex="7" />
            </GridPane>
         </VBox>

         <!-- RIGHT: Summary + Action -->
         <VBox spacing="16.0" maxWidth="300.0" HBox.hgrow="ALWAYS">

            <!-- Price Summary Card -->
            <VBox spacing="0" styleClass="card" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">
               <padding><Insets bottom="26.0" left="22.0" right="22.0" top="22.0" /></padding>

               <Label text="📋  Order Summary" styleClass="section-blue"
                      style="-fx-font-size: 14px;">
                  <VBox.margin><Insets bottom="12.0" /></VBox.margin>
               </Label>

               <Separator style="-fx-opacity: 0.5;">
                  <VBox.margin><Insets bottom="16.0" /></VBox.margin>
               </Separator>

               <Label styleClass="subtitle-label"
                      text="Complete the form on the left to see your estimated price and confirm your spot."
                      wrapText="true" alignment="CENTER" textAlignment="CENTER"
                      style="-fx-font-size: 12.5px; -fx-line-spacing: 3;">
                  <VBox.margin><Insets bottom="20.0" /></VBox.margin>
               </Label>

               <Region VBox.vgrow="ALWAYS" />

               <!-- Price Display -->
               <VBox alignment="CENTER" spacing="4.0"
                     style="-fx-background-color: rgba(29,201,138,0.07); -fx-background-radius: 10; -fx-padding: 16 20;">
                  <VBox.margin><Insets bottom="16.0" /></VBox.margin>
                  <Label text="Estimated Price" styleClass="subtitle-label"
                         style="-fx-font-size: 11px;" />
                  <Label fx:id="priceEstimateLabel" alignment="CENTER" maxWidth="Infinity"
                         styleClass="section-blue" text="—" wrapText="true"
                         style="-fx-font-size: 22px; -fx-font-weight: bold;" />
               </VBox>

               <Region VBox.vgrow="ALWAYS" />

               <Label fx:id="statusLabel" alignment="CENTER" maxWidth="Infinity"
                      wrapText="true" style="-fx-font-size: 12px;">
                  <VBox.margin><Insets bottom="10.0" /></VBox.margin>
               </Label>

               <Button fx:id="submitBtn" maxWidth="Infinity" mnemonicParsing="false"
                       onAction="#submitOrder" styleClass="primary-btn"
                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 13;"
                       text="Check &amp; Book" />
            </VBox>

            <!-- Info hint card -->
            <VBox spacing="6.0"
                  style="-fx-background-color: rgba(76,158,232,0.06); -fx-background-radius: 10; -fx-border-color: rgba(76,158,232,0.14); -fx-border-radius: 10; -fx-border-width: 1; -fx-padding: 14 16;">
               <Label text="ℹ  How booking works" styleClass="body-label"
                      style="-fx-font-size: 12px; -fx-font-weight: bold;" />
               <Label wrapText="true" styleClass="subtitle-label"
                      style="-fx-font-size: 11.5px; -fx-line-spacing: 2;"
                      text="1. Fill in your details and click Check &amp; Book.&#10;2. If available, your booking is confirmed instantly.&#10;3. You'll get a confirmation email with your order ID." />
            </VBox>
         </VBox>
      </HBox>
   </center>
</BorderPane>
