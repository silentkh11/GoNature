<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="850.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.guest.CreateOrderController">
   <top>
      <BorderPane BorderPane.alignment="CENTER">
         <padding><Insets bottom="10.0" left="20.0" right="20.0" top="15.0" /></padding>
         <left>
            <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleGoBack" styleClass="back-link" text="&lt; Back to Main Menu" />
         </left>
         <right>
            <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
         </right>
      </BorderPane>
   </top>
   <center>
      <HBox spacing="25.0" alignment="CENTER" maxWidth="800.0">
         <BorderPane.margin><Insets bottom="30.0" /></BorderPane.margin>
         
         <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS" maxWidth="480.0">
            <padding><Insets bottom="25.0" left="30.0" right="30.0" top="25.0" /></padding>
            <Label styleClass="title-label" text="Plan Your Visit"><font><Font name="Segoe UI Bold" size="22.0" /></font></Label>
            <Separator />
            <GridPane hgap="15.0" vgap="15.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0" prefWidth="110.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
               </columnConstraints>
               
               <Label styleClass="body-label" text="Select Park:" GridPane.rowIndex="0"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <ComboBox fx:id="parkCombo" maxWidth="Infinity" promptText="Choose a Park" GridPane.columnIndex="1" GridPane.rowIndex="0" />
               
               <Label styleClass="body-label" text="Visitor ID:" GridPane.rowIndex="1"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <TextField fx:id="visitorIdField" promptText="ID Number" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               
               <Label styleClass="body-label" text="Email:" GridPane.rowIndex="2"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <TextField fx:id="emailField" promptText="example@mail.com" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               
               <Label styleClass="body-label" text="Phone:" GridPane.rowIndex="3"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <TextField fx:id="phoneField" promptText="05X-XXXXXXX" GridPane.columnIndex="1" GridPane.rowIndex="3" />
               
               <Label styleClass="body-label" text="Date:" GridPane.rowIndex="4"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <DatePicker fx:id="datePicker" maxWidth="Infinity" promptText="Select Date" GridPane.columnIndex="1" GridPane.rowIndex="4" />
               
               <Label styleClass="body-label" text="Time:" GridPane.rowIndex="5"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <ComboBox fx:id="timeCombo" maxWidth="Infinity" promptText="Select Time" GridPane.columnIndex="1" GridPane.rowIndex="5" />
               
               <Label styleClass="body-label" text="Visitors:" GridPane.rowIndex="6"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <TextField fx:id="visitorsField" promptText="1 - 15 people" GridPane.columnIndex="1" GridPane.rowIndex="6" />
               
               <Label styleClass="body-label" text="Order Type:" GridPane.rowIndex="7"><font><Font name="Segoe UI Bold" size="13.0"/></font></Label>
               <ComboBox fx:id="typeCombo" maxWidth="Infinity" promptText="Type of visit" GridPane.columnIndex="1" GridPane.rowIndex="7" />
            </GridPane>
         </VBox>
         
         <VBox spacing="20.0" maxWidth="280.0" HBox.hgrow="ALWAYS">
            <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS" alignment="TOP_CENTER">
               <padding><Insets bottom="25.0" left="20.0" right="20.0" top="25.0" /></padding>
               <Label styleClass="section-blue" text="Order Summary"><font><Font name="Segoe UI Bold" size="16.0" /></font></Label>
               <Separator />
               <Label styleClass="subtitle-label" text="Complete the form to see your estimated price and secure your spot." wrapText="true" alignment="CENTER" textAlignment="CENTER"/>
               <Region VBox.vgrow="ALWAYS" />
               <Label fx:id="priceEstimateLabel" alignment="CENTER" maxWidth="Infinity" styleClass="section-blue" text="—" wrapText="true">
                  <font><Font name="Segoe UI Bold" size="15.0" /></font>
               </Label>
               <Region VBox.vgrow="ALWAYS" />
               <Label fx:id="statusLabel" alignment="CENTER" maxWidth="Infinity" wrapText="true" />
               <Button fx:id="submitBtn" maxWidth="Infinity" mnemonicParsing="false" onAction="#submitOrder" styleClass="primary-btn" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 12;" text="Check &amp; Book" />
            </VBox>
         </VBox>
      </HBox>
   </center>
</BorderPane>