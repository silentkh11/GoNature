<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.GuestPortalController">
   
   <top>
      <Button mnemonicParsing="false" onAction="#handleGoBack" style="-fx-background-color: transparent; -fx-text-fill: #636e72; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true; -fx-font-size: 14px;" text="&lt; Back to Main Menu" BorderPane.alignment="TOP_LEFT">
         <BorderPane.margin>
            <Insets left="20.0" top="20.0" />
         </BorderPane.margin>
      </Button>
   </top>

   <center>
      <VBox alignment="TOP_CENTER" spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="50.0" right="50.0" top="10.0" />
         </padding>
         <children>
            <Label style="-fx-text-fill: #2d3436;" text="Manage My Orders">
               <font>
                  <Font name="Segoe UI Bold" size="28.0" />
               </font>
            </Label>
            
            <HBox alignment="CENTER" spacing="15.0">
               <Label text="Enter ID Number:">
                  <font><Font name="Segoe UI Bold" size="16.0" /></font>
               </Label>
               <TextField fx:id="txtVisitorId" prefWidth="200.0" promptText="Your ID" style="-fx-font-size: 14px;" />
               <Button mnemonicParsing="false" onAction="#handleSearch" style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-background-radius: 5;" text="Find Orders" />
            </HBox>

            <TableView fx:id="ordersTable" prefHeight="300.0" prefWidth="750.0" style="-fx-background-radius: 5; -fx-border-color: #dfe6e9; -fx-border-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
              <columns>
                <TableColumn fx:id="colOrderId" prefWidth="100.0" text="Order ID" />
                <TableColumn fx:id="colParkId" prefWidth="100.0" text="Park ID" />
                <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" />
                <TableColumn fx:id="colTime" prefWidth="100.0" text="Time" />
                <TableColumn fx:id="colVisitors" prefWidth="100.0" text="Visitors" />
                <TableColumn fx:id="colStatus" prefWidth="180.0" text="Status" />
              </columns>
            </TableView>

            <Button fx:id="btnCancelOrder" mnemonicParsing="false" onAction="#handleCancelOrder" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #d63031; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand; -fx-background-radius: 5;" text="Cancel Selected Order" disable="true" />
            
            <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity" wrapText="true">
               <font><Font name="Segoe UI Bold" size="16.0" /></font>
            </Label>
         </children>
      </VBox>
   </center>
</BorderPane>