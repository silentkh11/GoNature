<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" styleClass="page-root"
             xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
             fx:controller="gui.service.ServiceRepController"
             style="-fx-border-color: transparent;">
   <content>
      <VBox alignment="TOP_CENTER" prefWidth="900.0" spacing="22.0" styleClass="page-root">
            <padding><Insets bottom="40.0" left="32.0" right="32.0" top="20.0" /></padding>

            <!-- Header Bar -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="header-bar">
               <Label text="🎧" style="-fx-font-size: 22px;" />
               <VBox spacing="1.0">
                  <Label text="Service Representative" styleClass="title-label"
                         style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                  <Label text="Visitor support · Subscriber enrollment · Order management"
                         styleClass="subtitle-label" style="-fx-font-size: 11px;" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblEmployeeName"
                      style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4C9EE8;" />
               <Button mnemonicParsing="false" onAction="#handleViewMyProfile"
                       style="-fx-background-color: rgba(255,255,255,0.07); -fx-border-color: rgba(255,255,255,0.14); -fx-border-radius: 9; -fx-border-width: 1; -fx-text-fill: rgba(213,227,239,0.78); -fx-font-size: 13px; -fx-padding: 7 15; -fx-cursor: hand; -fx-background-radius: 9;"
                       text="👤  Profile" />
               <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false"
                       onAction="#handleToggleTheme" styleClass="theme-toggle" text="☀ Light Mode" />
               <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleLogout"
                       styleClass="danger-btn"
                       style="-fx-font-size: 13px; -fx-padding: 7 16;" text="🚪  Logout" />
            </HBox>

            <!-- 2-column: Enroll Subscriber + Lookup Order -->
            <HBox spacing="20.0" alignment="TOP_CENTER">

               <!-- LEFT: Enroll New Subscriber -->
               <VBox spacing="0" styleClass="card" HBox.hgrow="ALWAYS"
                     style="-fx-border-color: rgba(29,201,138,0.14) rgba(29,201,138,0.14) rgba(29,201,138,0.14) rgba(29,201,138,0.60); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 14 14 0; -fx-background-radius: 0 14 14 0;">
                  <padding><Insets bottom="26.0" left="24.0" right="24.0" top="22.0" /></padding>

                  <HBox alignment="CENTER_LEFT" spacing="8.0">
                     <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                     <Label text="🌱" style="-fx-font-size: 16px;" />
                     <Label styleClass="section-blue" text="Enroll New Subscriber"
                            style="-fx-font-size: 15px;" />
                  </HBox>

                  <Label styleClass="subtitle-label"
                         text="Register a visitor as a GoNature subscriber."
                         wrapText="true" style="-fx-font-size: 12px;">
                     <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                  </Label>

                  <GridPane hgap="14.0" vgap="13.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="95.0" prefWidth="105.0" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                     </columnConstraints>

                     <Label text="Visitor ID" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="0" />
                     <TextField fx:id="enrollId" promptText="9-digit ID"
                                GridPane.columnIndex="1" GridPane.rowIndex="0" />

                     <Label text="First Name" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="1" />
                     <TextField fx:id="enrollFirst" promptText="First name"
                                GridPane.columnIndex="1" GridPane.rowIndex="1" />

                     <Label text="Last Name" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="2" />
                     <TextField fx:id="enrollLast" promptText="Last name"
                                GridPane.columnIndex="1" GridPane.rowIndex="2" />

                     <Label text="Email" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="3" />
                     <TextField fx:id="enrollEmail" promptText="example@mail.com"
                                GridPane.columnIndex="1" GridPane.rowIndex="3" />

                     <Label text="Phone" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="4" />
                     <TextField fx:id="enrollPhone" promptText="05X-XXXXXXX"
                                GridPane.columnIndex="1" GridPane.rowIndex="4" />

                     <Label text="Family Size" styleClass="body-label"
                            style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="5" />
                     <TextField fx:id="enrollFamily" promptText="Default: 1"
                                GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  </GridPane>

                  <CheckBox fx:id="enrollGuide" mnemonicParsing="false"
                            text="Certified Tour Guide  🏕️">
                     <font><Font name="Segoe UI" size="13.0" /></font>
                     <VBox.margin><Insets top="14.0" bottom="14.0" /></VBox.margin>
                  </CheckBox>

                  <Button fx:id="btnEnroll" mnemonicParsing="false" onAction="#handleEnrollSubscriber"
                          prefHeight="44.0" maxWidth="Infinity"
                          styleClass="primary-btn"
                          style="-fx-font-size: 14px; -fx-font-weight: bold;"
                          text="Enroll Subscriber" />

                  <Label fx:id="lblEnrollStatus" alignment="CENTER" maxWidth="Infinity"
                         wrapText="true" style="-fx-font-size: 12px;">
                     <VBox.margin><Insets top="8.0" /></VBox.margin>
                  </Label>
               </VBox>

               <!-- RIGHT: Lookup Visitor / Order -->
               <VBox spacing="18.0" HBox.hgrow="ALWAYS">

                  <!-- Visitor Lookup -->
                  <VBox spacing="0" styleClass="card"
                        style="-fx-border-color: rgba(76,158,232,0.14) rgba(76,158,232,0.14) rgba(76,158,232,0.14) rgba(76,158,232,0.60); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 14 14 0; -fx-background-radius: 0 14 14 0;">
                     <padding><Insets bottom="22.0" left="22.0" right="22.0" top="20.0" /></padding>

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <VBox.margin><Insets bottom="6.0" /></VBox.margin>
                        <Label text="🔍" style="-fx-font-size: 14px;" />
                        <Label styleClass="section-blue" text="Find Visitor / Order"
                               style="-fx-font-size: 14px;" />
                     </HBox>

                     <Separator style="-fx-opacity: 0.5;">
                        <VBox.margin><Insets bottom="14.0" /></VBox.margin>
                     </Separator>

                     <GridPane hgap="12.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="90.0" prefWidth="100.0" />
                           <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                        </columnConstraints>

                        <Label text="Visitor ID" styleClass="body-label"
                               style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="0" />
                        <TextField fx:id="lookupId" promptText="Enter visitor ID"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Order ID" styleClass="body-label"
                               style="-fx-font-weight: bold; -fx-font-size: 12px;" GridPane.rowIndex="1" />
                        <TextField fx:id="lookupOrderId" promptText="Optional — search by order"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </GridPane>

                     <Button fx:id="btnLookup" mnemonicParsing="false" onAction="#handleLookup"
                             prefHeight="42.0" maxWidth="Infinity"
                             styleClass="secondary-btn"
                             style="-fx-font-weight: bold; -fx-font-size: 13px;"
                             text="Search">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                     </Button>
                  </VBox>

                  <!-- Lookup Results -->
                  <VBox spacing="12.0" styleClass="card" VBox.vgrow="ALWAYS">
                     <padding><Insets bottom="18.0" left="22.0" right="22.0" top="18.0" /></padding>
                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="📋" style="-fx-font-size: 14px;" />
                        <Label styleClass="section-blue" text="Results"
                               style="-fx-font-size: 14px;" />
                     </HBox>
                     <TableView fx:id="lookupTable" prefHeight="200.0">
                        <columns>
                           <TableColumn fx:id="colLookupField"  prefWidth="130.0" text="Field" />
                           <TableColumn fx:id="colLookupValue"  prefWidth="250.0" text="Value" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                     </TableView>
                     <Label fx:id="lblLookupStatus" alignment="CENTER" maxWidth="Infinity"
                            wrapText="true" style="-fx-font-size: 12.5px;" />
                  </VBox>
               </VBox>
            </HBox>

         </VBox>
   </content>
</ScrollPane>
