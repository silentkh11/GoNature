<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="800.0" prefWidth="980.0" style="-fx-background-color: transparent;"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.management.DeptManagerReportsController">

   <ScrollPane fitToWidth="true"
               style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
      <content>
         <VBox alignment="TOP_CENTER" prefWidth="980.0" spacing="20.0" styleClass="page-root">
            <padding><Insets bottom="40.0" left="32.0" right="32.0" top="0.0" /></padding>

            <!-- ── HEADER BAR ─────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="header-bar">
               <Label text="📈" style="-fx-font-size: 20px;" />
               <VBox spacing="1.0">
                  <Label text="Department Reports" styleClass="title-label"
                         style="-fx-font-size: 18px; -fx-font-weight: 700;" />
                  <Label text="Cross-park analytics · Demand trends · Usage benchmarks"
                         styleClass="subtitle-label" style="-fx-font-size: 11px;" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Button mnemonicParsing="false" onAction="#handleGoBack"
                       styleClass="back-link" text="← Back to Dashboard" />
               <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false"
                       onAction="#handleToggleTheme" styleClass="theme-toggle" text="☀ Light" />
            </HBox>

            <!-- ── STAT SUMMARY ROW ───────────────────────── -->
            <HBox spacing="16.0" alignment="CENTER">
               <VBox styleClass="stat-chip-brand" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="TOTAL VISITORS" styleClass="stat-caption" />
                  <Label fx:id="lblTotalVisitors" text="—" styleClass="stat-num-brand" />
                  <Label text="All parks, selected period" styleClass="stat-caption" />
               </VBox>
               <VBox styleClass="stat-chip-amber" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="TOTAL INCOME" styleClass="stat-caption" />
                  <Label fx:id="lblTotalIncome" text="—" styleClass="stat-num-amber" />
                  <Label text="Revenue across parks" styleClass="stat-caption" />
               </VBox>
            </HBox>

            <!-- ── FILTER ROW ─────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="card"
                  style="-fx-padding: 14 20;">
               <Label text="🏞" style="-fx-font-size: 15px;" />
               <Label styleClass="body-label" text="Park"
                      style="-fx-font-weight: 700; -fx-font-size: 13px;" />
               <ComboBox fx:id="cmbPark" prefWidth="200.0" promptText="All Parks"
                         style="-fx-font-size: 13px; -fx-cursor: hand;" />

               <Separator orientation="VERTICAL" style="-fx-opacity: 0.5;" />

               <Label styleClass="body-label" text="Month"
                      style="-fx-font-weight: 700; -fx-font-size: 13px;" />
               <ComboBox fx:id="cmbMonth" prefWidth="140.0" promptText="Month"
                         style="-fx-font-size: 13px; -fx-cursor: hand;" />

               <Label styleClass="body-label" text="Year"
                      style="-fx-font-weight: 700; -fx-font-size: 13px;" />
               <ComboBox fx:id="cmbYear" prefWidth="110.0" promptText="Year"
                         style="-fx-font-size: 13px; -fx-cursor: hand;" />

               <Region HBox.hgrow="ALWAYS" />
               <Button mnemonicParsing="false" onAction="#handleVisitReport"
                       styleClass="primary-btn"
                       style="-fx-font-weight: 700; -fx-padding: 9 20; -fx-font-size: 13px;"
                       text="Visit Report" />
               <Button mnemonicParsing="false" onAction="#handleCancellationsReport"
                       styleClass="danger-btn"
                       style="-fx-font-weight: 700; -fx-padding: 9 20; -fx-font-size: 13px;"
                       text="Cancellations" />
               <Button mnemonicParsing="false" onAction="#handleViewSubmittedReport"
                       styleClass="secondary-btn"
                       style="-fx-font-weight: 700; -fx-padding: 9 18; -fx-font-size: 13px;"
                       text="Submitted Reports" />
            </HBox>

            <!-- ── CHARTS ROW ─────────────────────────────── -->
            <HBox spacing="18.0">

               <!-- Visitor Pie Chart — cross-park breakdown -->
               <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10.0"
                     style="-fx-border-color: #E2DFD9 #E2DFD9 #E2DFD9 #1A7A5E; -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                  <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                  <Label text="Visitor Distribution — All Parks" styleClass="section-blue"
                         style="-fx-font-size: 13px;" />
                  <PieChart fx:id="visitorPieChart" prefHeight="260.0" animated="false"
                            legendVisible="true" />
               </VBox>

               <!-- Income Bar Chart — monthly comparison -->
               <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10.0"
                     style="-fx-border-color: #E2DFD9 #E2DFD9 #E2DFD9 #B8750A; -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                  <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                  <Label text="Monthly Revenue Comparison" styleClass="section-gold"
                         style="-fx-font-size: 13px;" />
                  <BarChart fx:id="incomeBarChart" prefHeight="260.0" animated="false">
                     <xAxis><CategoryAxis label="Month" /></xAxis>
                     <yAxis><NumberAxis label="Income (ILS)" /></yAxis>
                  </BarChart>
               </VBox>
            </HBox>

            <!-- ── STATUS ─────────────────────────────────── -->
            <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity"
                   wrapText="true" minHeight="24.0"
                   style="-fx-font-size: 13px; -fx-font-weight: 700;" />

         </VBox>
      </content>
   </ScrollPane>
</StackPane>
