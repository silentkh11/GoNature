<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="780.0" prefWidth="1000.0" styleClass="page-root"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.management.DeptManagerController">

   <ScrollPane fitToWidth="true" fitToHeight="true"
               style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
      <content>
         <VBox alignment="TOP_CENTER" prefWidth="1000.0" spacing="0" styleClass="page-root">

            <!-- ── HEADER BAR ─────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="header-bar">
               <Label text="🏛" style="-fx-font-size: 20px;" />
               <VBox spacing="1.0">
                  <Label text="Department Manager" styleClass="title-label"
                         style="-fx-font-size: 18px; -fx-font-weight: 700;" />
                  <Label text="Approve requests · Manage promotions · Monitor connected users"
                         styleClass="subtitle-label" style="-fx-font-size: 11px;" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblEmployeeName"
                      style="-fx-font-size: 12px; -fx-font-weight: 600;" styleClass="body-label" />
               <Button mnemonicParsing="false" onAction="#handleViewMyProfile"
                       styleClass="secondary-btn"
                       style="-fx-font-size: 12px; -fx-padding: 6 14;" text="👤  Profile" />
               <Button mnemonicParsing="false" onAction="#handleViewReports"
                       styleClass="primary-btn"
                       style="-fx-font-size: 12px; -fx-padding: 6 14;" text="📊  Reports" />
               <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false"
                       onAction="#handleToggleTheme" styleClass="theme-toggle" text="☀ Light" />
               <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleGoBack"
                       styleClass="back-link"
                       style="-fx-font-size: 12px; -fx-padding: 6 14;" text="← Main Menu" />
               <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleLogout"
                       styleClass="danger-btn"
                       style="-fx-font-size: 12px; -fx-padding: 6 14;" text="Logout" />
            </HBox>

            <!-- ── MAIN CONTENT ───────────────────────────── -->
            <HBox spacing="16.0" alignment="TOP_LEFT">
               <padding><Insets bottom="28.0" left="24.0" right="24.0" top="20.0" /></padding>

               <!-- ─ LEFT COLUMN (wider) ─────────────────── -->
               <VBox spacing="14.0" HBox.hgrow="ALWAYS">

                  <!-- Parameter Requests section -->
                  <VBox styleClass="card" spacing="12.0"
                        style="-fx-border-color: rgba(29,201,138,0.14) rgba(29,201,138,0.14) rgba(29,201,138,0.14) rgba(29,201,138,0.70); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="18.0" /></padding>

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="⚙️" style="-fx-font-size: 14px;" />
                        <Label text="Parameter Change Requests" styleClass="section-blue"
                               style="-fx-font-size: 14px;" />
                     </HBox>

                     <TableView fx:id="requestsTable" prefHeight="160.0">
                        <columns>
                           <TableColumn fx:id="colReqId"    prefWidth="70.0"  text="ID" />
                           <TableColumn fx:id="colPark"     prefWidth="160.0" text="Park" />
                           <TableColumn fx:id="colCapacity" prefWidth="120.0" text="Max Capacity" />
                           <TableColumn fx:id="colGap"      prefWidth="110.0" text="Casual Gap" />
                           <TableColumn fx:id="colTime"     prefWidth="110.0" text="Est. Time" />
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                     </TableView>

                     <HBox spacing="10.0">
                        <Button fx:id="btnApprove" mnemonicParsing="false" onAction="#handleApprove"
                                prefHeight="40.0" prefWidth="140.0"
                                styleClass="success-btn" text="✓ Approve" />
                        <Button fx:id="btnDeny" mnemonicParsing="false" onAction="#handleDeny"
                                prefHeight="40.0" prefWidth="140.0"
                                styleClass="danger-btn" text="✕ Deny" />
                     </HBox>
                  </VBox>

                  <!-- Promotions section -->
                  <VBox styleClass="card" spacing="12.0"
                        style="-fx-border-color: rgba(232,160,32,0.14) rgba(232,160,32,0.14) rgba(232,160,32,0.14) rgba(232,160,32,0.70); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="18.0" /></padding>

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="🏷" style="-fx-font-size: 14px;" />
                        <Label text="Pending Promotions" styleClass="section-gold"
                               style="-fx-font-size: 14px;" />
                     </HBox>

                     <TableView fx:id="promotionsTable" prefHeight="160.0">
                        <columns>
                           <TableColumn fx:id="colPromoId"       prefWidth="70.0"  text="ID" />
                           <TableColumn fx:id="colPromoPark"     prefWidth="180.0" text="Park" />
                           <TableColumn fx:id="colPromoDiscount" prefWidth="130.0" text="Discount" />
                           <TableColumn fx:id="colPromoStatus"   prefWidth="130.0" text="Status" />
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                     </TableView>

                     <HBox spacing="10.0">
                        <Button fx:id="btnApprovePromo" mnemonicParsing="false"
                                onAction="#handleApprovePromotion"
                                prefHeight="40.0" prefWidth="160.0"
                                styleClass="gold-btn" text="✓ Approve Promo" />
                        <Button fx:id="btnDenyPromo" mnemonicParsing="false"
                                onAction="#handleDenyPromotion"
                                prefHeight="40.0" prefWidth="140.0"
                                styleClass="danger-btn" text="✕ Deny" />
                     </HBox>
                  </VBox>

                  <!-- Nature dark zone — Cancel Discount -->
                  <VBox styleClass="park-section" spacing="12.0">

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="🌲" style="-fx-font-size: 16px;" />
                        <VBox spacing="2.0">
                           <Label text="Cancel Active Promotion" styleClass="park-section-title" />
                           <Label text="Remove a park's running discount immediately"
                                  styleClass="park-section-subtitle" />
                        </VBox>
                     </HBox>

                     <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <Label text="Park" styleClass="park-label-dark" />
                        <ComboBox fx:id="cmbCancelPark" prefWidth="240.0"
                                  promptText="Select park to cancel discount…"
                                  style="-fx-font-size: 13px;" />
                        <Label text="Active:" styleClass="park-label-dark" />
                        <Label fx:id="lblActiveParkDiscount" text="—"
                               styleClass="park-accent-text"
                               style="-fx-font-size: 14px;" />
                     </HBox>

                     <Button fx:id="btnCancelDiscount" mnemonicParsing="false"
                             onAction="#handleCancelPromotion"
                             prefHeight="42.0" maxWidth="Infinity"
                             styleClass="danger-btn"
                             style="-fx-font-weight: 700; -fx-font-size: 13px;"
                             text="Cancel Active Discount" />
                  </VBox>

                  <!-- Status card -->
                  <VBox styleClass="card" spacing="8.0">
                     <padding><Insets bottom="16.0" left="18.0" right="18.0" top="14.0" /></padding>
                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="🔔" style="-fx-font-size: 14px;" />
                        <Label text="System Status" styleClass="section-blue"
                               style="-fx-font-size: 13px;" />
                     </HBox>
                     <Separator />
                     <Label fx:id="lblStatus" maxWidth="Infinity" wrapText="true"
                            minHeight="48.0"
                            style="-fx-font-size: 12.5px; -fx-line-spacing: 4;"
                            styleClass="body-label" />
                  </VBox>

               </VBox>

               <!-- ─ RIGHT COLUMN (connected users) ───────── -->
               <VBox spacing="14.0" minWidth="260.0" maxWidth="280.0">

                  <!-- Connected Users card -->
                  <VBox styleClass="card" spacing="10.0" VBox.vgrow="ALWAYS">
                     <padding><Insets bottom="18.0" left="18.0" right="18.0" top="16.0" /></padding>

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="👥" style="-fx-font-size: 16px;" />
                        <VBox spacing="1.0">
                           <Label text="Connected Users" styleClass="section-blue"
                                  style="-fx-font-size: 13px;" />
                           <Label fx:id="lblUserCount" text="0 online"
                                  styleClass="subtitle-label" style="-fx-font-size: 11px;" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleRefreshUsers"
                                styleClass="secondary-btn"
                                style="-fx-font-size: 11px; -fx-padding: 4 10;" text="↻ Refresh" />
                     </HBox>

                     <Separator />

                     <ListView fx:id="connectedUsersList" prefHeight="480.0" VBox.vgrow="ALWAYS" />
                  </VBox>

               </VBox>

            </HBox>

            <!-- Elastic spacer — pushes footer to viewport bottom -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Footer strip -->
            <HBox alignment="CENTER_LEFT" styleClass="employee-footer">
               <Label text="🏛  GoNature Platform  ·  Department Management" styleClass="employee-footer-text" />
               <Region HBox.hgrow="ALWAYS" />
               <Label text="Request Approval &amp; Connected Users Monitor" styleClass="employee-footer-text" />
            </HBox>

         </VBox>
      </content>
   </ScrollPane>
</StackPane>
