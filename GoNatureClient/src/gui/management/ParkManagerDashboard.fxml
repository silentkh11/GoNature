<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.management.ParkManagerController">
   <content>
      
      <VBox alignment="TOP_CENTER" prefWidth="880.0" spacing="25.0" styleClass="page-root">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="20.0" />
         </padding>

         <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Button mnemonicParsing="false" onAction="#handleViewReports" prefHeight="38.0" styleClass="primary-btn" style="-fx-font-size: 14px; -fx-cursor: hand;" text="📊 View Statistical Reports" />
            <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme" prefHeight="38.0" styleClass="theme-toggle" style="-fx-font-size: 14px; -fx-cursor: hand;" text="🌙 Dark Mode" />
            <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="38.0" styleClass="danger-btn" style="-fx-font-size: 14px; -fx-padding: 5 18; -fx-cursor: hand;" text="🚪 Logout" />
         </HBox>

         <VBox alignment="CENTER" spacing="14.0">
            <Label styleClass="title-label" text="Park Manager Dashboard">
               <font><Font name="Segoe UI Bold" size="32.0" /></font>
            </Label>
            <ComboBox fx:id="parkCombo" prefHeight="42.0" prefWidth="320.0" promptText="Select Park to Edit..." style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" />
         </VBox>

         <HBox alignment="TOP_CENTER" spacing="30.0">
             
             <VBox styleClass="card" spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="400.0">
                 <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                 </padding>
                 <Label text="Current Park Parameters" styleClass="card-title">
                     <font><Font name="Segoe UI Bold" size="18.0" /></font>
                 </Label>
                 <GridPane vgap="12.0" hgap="10.0">
                     <columnConstraints>
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" />
                     </columnConstraints>
                     <Label text="Park Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="body-label" />
                     <Label fx:id="lblParkName" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-weight: bold;" styleClass="body-label" />

                     <Label text="Max Capacity:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="body-label" />
                     <Label fx:id="lblMaxCapacity" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-weight: bold;" styleClass="body-label" />

                     <Label text="Casual Gap:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="body-label" />
                     <Label fx:id="lblCasualGap" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-weight: bold;" styleClass="body-label" />

                     <Label text="Est. Stay (Hours):" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="body-label" />
                     <Label fx:id="lblEstStay" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-font-weight: bold;" styleClass="body-label" />

                     <Label text="Current Visitors:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="body-label" />
                     <Label fx:id="lblCurrentVisitors" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #00b894;" />

                     <Label text="Active Discount:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="body-label" />
                     <Label fx:id="lblActiveDiscount" text="-" GridPane.rowIndex="5" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #0984e3;" />
                 </GridPane>
             </VBox>

             <VBox styleClass="card" spacing="15.0" HBox.hgrow="ALWAYS" prefWidth="400.0">
                 <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                 </padding>
                 <Label text="Request Parameter Update" styleClass="card-title">
                     <font><Font name="Segoe UI Bold" size="18.0" /></font>
                 </Label>
                 <GridPane vgap="12.0" hgap="10.0">
                     <columnConstraints>
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" />
                     </columnConstraints>
                     <Label text="New Max Capacity:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="body-label" />
                     <TextField fx:id="txtNewMaxCapacity" promptText="e.g. 500" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                     <Label text="New Casual Gap:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="body-label" />
                     <TextField fx:id="txtNewCasualGap" promptText="e.g. 50" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                     <Label text="New Est. Stay:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="body-label" />
                     <TextField fx:id="txtNewEstStay" promptText="e.g. 4" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                 </GridPane>
                 <Button mnemonicParsing="false" onAction="#submitParameters" prefHeight="35.0" maxWidth="Infinity" styleClass="primary-btn" style="-fx-font-weight: bold; -fx-cursor: hand;" text="Submit Parameter Request" />
             </VBox>
         </HBox>

         <VBox styleClass="card" spacing="15.0" maxWidth="830.0">
             <padding>
                 <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
             </padding>
             <Label text="Request Promotional Discount" styleClass="card-title">
                 <font><Font name="Segoe UI Bold" size="18.0" /></font>
             </Label>
             <HBox spacing="15.0" alignment="CENTER_LEFT">
                 <Label text="Discount Percentage (%):" styleClass="body-label" />
                 <TextField fx:id="txtDiscountPercent" promptText="e.g. 20" prefWidth="100.0" />
                 <Button fx:id="btnSubmitPromotion" mnemonicParsing="false" onAction="#handleSubmitPromotion" prefHeight="35.0" styleClass="secondary-btn" style="-fx-font-weight: bold; -fx-cursor: hand;" text="Submit Promotion Request" />
             </HBox>
         </VBox>

         <Label fx:id="lblStatus" text="" alignment="CENTER" maxWidth="Infinity">
             <font><Font name="Segoe UI Bold" size="14.0" /></font>
         </Label>

      </VBox>
   </content>
</ScrollPane>