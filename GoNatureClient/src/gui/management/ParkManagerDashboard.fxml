<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="720.0" prefWidth="900.0" style="-fx-background-color: transparent;"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.management.ParkManagerController">

   <ScrollPane fitToWidth="true" fitToHeight="false"
               style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
      <content>
         <VBox alignment="TOP_CENTER" prefWidth="900.0" spacing="0" styleClass="page-root">

            <!-- ── HEADER BAR ─────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="header-bar">
               <Label text="🏕" style="-fx-font-size: 20px;" />
               <VBox spacing="1.0">
                  <Label text="Park Manager" styleClass="title-label"
                         style="-fx-font-size: 18px; -fx-font-weight: 700;" />
                  <Label styleClass="subtitle-label" style="-fx-font-size: 11px;"
                         text="Configure park parameters and request promotions" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Label fx:id="lblEmployeeName"
                      style="-fx-font-size: 12px; -fx-font-weight: 600;" styleClass="body-label" />
               <Button mnemonicParsing="false" onAction="#handleViewMyProfile"
                       styleClass="secondary-btn"
                       style="-fx-font-size: 12px; -fx-padding: 6 14;" text="👤  Profile" />
               <Button mnemonicParsing="false" onAction="#handleViewReports"
                       styleClass="primary-btn"
                       style="-fx-font-size: 12px; -fx-padding: 6 14;" text="📊  Reports" />
               <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false"
                       onAction="#handleToggleTheme" styleClass="theme-toggle" text="☀ Light" />
               <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleLogout"
                       styleClass="danger-btn"
                       style="-fx-font-size: 12px; -fx-padding: 6 14;" text="Logout" />
            </HBox>

            <!-- ── PARK SELECTOR BAR ──────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="14.0"
                  style="-fx-background-color: -fx-background; -fx-padding: 12 24; -fx-border-color: transparent transparent #E2DFD9 transparent; -fx-border-width: 0 0 1 0;">
               <Label text="🏞" style="-fx-font-size: 15px;" />
               <Label styleClass="body-label" text="Active Park"
                      style="-fx-font-weight: 700; -fx-font-size: 13px;" />
               <ComboBox fx:id="parkCombo" prefWidth="320.0"
                         promptText="Select the park you manage…"
                         style="-fx-font-size: 13px; -fx-font-weight: 600;" />
            </HBox>

            <!-- ── STAT CHIPS ROW ─────────────────────────── -->
            <HBox spacing="14.0" alignment="CENTER">
               <padding><Insets bottom="16.0" left="24.0" right="24.0" top="18.0" /></padding>

               <!-- Current Visitors -->
               <VBox styleClass="stat-chip-brand" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="CURRENT VISITORS" styleClass="stat-caption" />
                  <Label fx:id="lblCurrentVisitors" text="—" styleClass="stat-num-brand" />
                  <Label text="Live headcount" styleClass="stat-caption" />
               </VBox>

               <!-- Max Capacity -->
               <VBox styleClass="stat-chip-sky" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="MAX CAPACITY" styleClass="stat-caption" />
                  <Label fx:id="lblMaxCapacity" text="—" styleClass="stat-num-sky" />
                  <Label text="Total allowed" styleClass="stat-caption" />
               </VBox>

               <!-- Active Discount -->
               <VBox styleClass="stat-chip-amber" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="ACTIVE DISCOUNT" styleClass="stat-caption" />
                  <Label fx:id="lblActiveDiscount" text="—" styleClass="stat-num-amber" />
                  <Label text="Promotional rate" styleClass="stat-caption" />
               </VBox>

               <!-- Est. Stay -->
               <VBox styleClass="stat-chip-neutral" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="EST. STAY" styleClass="stat-caption" />
                  <Label fx:id="lblEstStay" text="—" styleClass="stat-num" />
                  <Label text="Average hours" styleClass="stat-caption" />
               </VBox>
            </HBox>

            <!-- ── MAIN TWO-COLUMN LAYOUT ─────────────────── -->
            <HBox spacing="16.0" alignment="TOP_CENTER">
               <padding><Insets bottom="28.0" left="24.0" right="24.0" /></padding>

               <!-- ─ LEFT COLUMN (wider) ─────────────────── -->
               <VBox spacing="14.0" HBox.hgrow="ALWAYS">

                  <!-- Live Park Details card -->
                  <VBox styleClass="card" spacing="12.0"
                        style="-fx-border-color: #E2DFD9 #E2DFD9 #E2DFD9 #1A7A5E; -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="18.0" /></padding>

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="⚙️" style="-fx-font-size: 14px;" />
                        <Label text="Live Park Details" styleClass="section-blue"
                               style="-fx-font-size: 14px;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblParkName"
                               style="-fx-font-size: 13px; -fx-font-weight: 700;" styleClass="body-label" />
                     </HBox>

                     <Separator />

                     <GridPane hgap="16.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="140.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="140.0" />
                           <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>

                        <Label text="Casual Gap" styleClass="body-label"
                               style="-fx-font-weight: 700; -fx-font-size: 12px;"
                               GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <Label fx:id="lblCasualGap" text="—"
                               style="-fx-font-size: 14px; -fx-font-weight: 700;"
                               styleClass="section-blue"
                               GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Max Visitors" styleClass="body-label"
                               style="-fx-font-weight: 700; -fx-font-size: 12px;"
                               GridPane.rowIndex="0" GridPane.columnIndex="2" />
                        <Label text="—" style="-fx-font-size: 14px; -fx-font-weight: 700;"
                               styleClass="section-blue"
                               GridPane.rowIndex="0" GridPane.columnIndex="3" />
                     </GridPane>
                  </VBox>

                  <!-- Parameter Update Form card -->
                  <VBox styleClass="card" spacing="14.0">
                     <padding><Insets bottom="22.0" left="20.0" right="20.0" top="18.0" /></padding>

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="📝" style="-fx-font-size: 14px;" />
                        <Label text="Request Parameter Update" styleClass="section-blue"
                               style="-fx-font-size: 14px;" />
                     </HBox>

                     <Label styleClass="subtitle-label"
                            text="Submit new capacity rules to the Department Manager for approval."
                            wrapText="true" style="-fx-font-size: 12px;" />

                     <GridPane hgap="14.0" vgap="12.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="130.0" />
                           <ColumnConstraints hgrow="ALWAYS" minWidth="80.0" />
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="130.0" />
                           <ColumnConstraints hgrow="ALWAYS" minWidth="80.0" />
                        </columnConstraints>

                        <Label text="New Max Capacity" styleClass="body-label"
                               style="-fx-font-weight: 700; -fx-font-size: 12px;"
                               GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="txtNewMaxCapacity" promptText="e.g. 500"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1" />

                        <Label text="Casual Gap" styleClass="body-label"
                               style="-fx-font-weight: 700; -fx-font-size: 12px;"
                               GridPane.rowIndex="0" GridPane.columnIndex="2" />
                        <TextField fx:id="txtNewCasualGap" promptText="e.g. 40"
                                   GridPane.rowIndex="0" GridPane.columnIndex="3" />

                        <Label text="Est. Stay (hrs)" styleClass="body-label"
                               style="-fx-font-weight: 700; -fx-font-size: 12px;"
                               GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="txtNewEstStay" promptText="e.g. 4"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1" />
                     </GridPane>

                     <Button mnemonicParsing="false" onAction="#submitParameters"
                             prefHeight="42.0" maxWidth="Infinity"
                             styleClass="secondary-btn"
                             style="-fx-font-weight: 700; -fx-font-size: 13px;"
                             text="Submit Parameter Request to Department Manager" />
                  </VBox>
               </VBox>

               <!-- ─ RIGHT COLUMN (narrower) ─────────────── -->
               <VBox spacing="14.0" maxWidth="295.0" minWidth="265.0">

                  <!-- Promotional Discount card -->
                  <VBox styleClass="card" spacing="14.0"
                        style="-fx-border-color: #E2DFD9 #E2DFD9 #E2DFD9 #B8750A; -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                     <padding><Insets bottom="20.0" left="18.0" right="18.0" top="18.0" /></padding>

                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="🏷" style="-fx-font-size: 14px;" />
                        <Label text="Promotional Discount" styleClass="section-gold"
                               style="-fx-font-size: 14px;" />
                     </HBox>

                     <Label styleClass="subtitle-label" wrapText="true"
                            text="Request a temporary discount for your park."
                            style="-fx-font-size: 12px;" />

                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Discount" styleClass="body-label"
                               style="-fx-font-weight: 700; -fx-font-size: 12px;" />
                        <TextField fx:id="txtDiscountPercent" prefWidth="70.0" prefHeight="42.0"
                                   promptText="1-100"
                                   style="-fx-alignment: center; -fx-font-size: 16px; -fx-font-weight: 700;" />
                        <Label text="pct" styleClass="body-label"
                               style="-fx-font-size: 14px; -fx-font-weight: 700;" />
                     </HBox>

                     <Button fx:id="btnSubmitPromotion" mnemonicParsing="false"
                             onAction="#handleSubmitPromotion"
                             prefHeight="42.0" maxWidth="Infinity"
                             styleClass="gold-btn"
                             style="-fx-font-weight: 700; -fx-font-size: 13px;"
                             text="Request Promotion" />
                  </VBox>

                  <!-- Status card -->
                  <VBox styleClass="card" spacing="10.0" VBox.vgrow="ALWAYS">
                     <padding><Insets bottom="18.0" left="18.0" right="18.0" top="16.0" /></padding>
                     <HBox alignment="CENTER_LEFT" spacing="8.0">
                        <Label text="🔔" style="-fx-font-size: 14px;" />
                        <Label text="System Status" styleClass="section-blue"
                               style="-fx-font-size: 13px;" />
                     </HBox>
                     <Separator />
                     <Label fx:id="lblStatus" alignment="TOP_LEFT" maxWidth="Infinity"
                            wrapText="true" minHeight="60.0"
                            style="-fx-font-size: 12.5px; -fx-line-spacing: 4;"
                            styleClass="body-label" />
                  </VBox>

                  <!-- Quick Actions card -->
                  <VBox styleClass="card" spacing="8.0">
                     <padding><Insets bottom="16.0" left="18.0" right="18.0" top="14.0" /></padding>
                     <Label text="Quick Actions" styleClass="section-blue"
                            style="-fx-font-size: 13px;" />
                     <Button mnemonicParsing="false" onAction="#handleViewReports"
                             prefHeight="38.0" maxWidth="Infinity"
                             styleClass="primary-btn"
                             style="-fx-font-size: 12px;" text="📊  View Full Reports" />
                     <Button mnemonicParsing="false" onAction="#handleViewMyProfile"
                             prefHeight="38.0" maxWidth="Infinity"
                             styleClass="secondary-btn"
                             style="-fx-font-size: 12px;" text="👤  My Profile" />
                  </VBox>
               </VBox>
            </HBox>

         </VBox>
      </content>
   </ScrollPane>
</StackPane>
