<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="780.0" prefWidth="960.0" style="-fx-background-color: transparent;"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.management.ParkManagerReportsController">

   <ScrollPane fitToWidth="true"
               style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
      <content>
         <VBox alignment="TOP_CENTER" prefWidth="960.0" spacing="20.0" styleClass="page-root">
            <padding><Insets bottom="40.0" left="32.0" right="32.0" top="0.0" /></padding>

            <!-- ── HEADER BAR ─────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="header-bar">
               <Label text="📊" style="-fx-font-size: 20px;" />
               <VBox spacing="1.0">
                  <Label text="Park Reports" styleClass="title-label"
                         style="-fx-font-size: 18px; -fx-font-weight: 700;" />
                  <Label text="Visitor trends · Capacity analytics · Order statistics"
                         styleClass="subtitle-label" style="-fx-font-size: 11px;" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Button mnemonicParsing="false" onAction="#handleGoBack"
                       styleClass="back-link" text="← Back to Dashboard" />
               <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false"
                       onAction="#handleToggleTheme" styleClass="theme-toggle" text="☀ Light" />
            </HBox>

            <!-- ── STAT SUMMARY ROW ───────────────────────── -->
            <HBox spacing="16.0" alignment="CENTER">
               <VBox styleClass="stat-chip-brand" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="TOTAL VISITORS" styleClass="stat-caption" />
                  <Label fx:id="lblTotalVisitors" text="—" styleClass="stat-num-brand" />
                  <Label text="In selected period" styleClass="stat-caption" />
               </VBox>
               <VBox styleClass="stat-chip-amber" HBox.hgrow="ALWAYS" spacing="4.0">
                  <Label text="TOTAL INCOME" styleClass="stat-caption" />
                  <Label fx:id="lblTotalIncome" text="—" styleClass="stat-num-amber" />
                  <Label text="Revenue this period" styleClass="stat-caption" />
               </VBox>
            </HBox>

            <!-- ── FILTER ROW ─────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="card"
                  style="-fx-padding: 14 20;">
               <Label text="📅" style="-fx-font-size: 15px;" />
               <Label styleClass="body-label" text="Month"
                      style="-fx-font-weight: 700; -fx-font-size: 13px;" />
               <ComboBox fx:id="monthCombo" prefWidth="160.0" promptText="Select month…"
                         style="-fx-font-size: 13px; -fx-cursor: hand;" />

               <Label styleClass="body-label" text="Year"
                      style="-fx-font-weight: 700; -fx-font-size: 13px;" />
               <ComboBox fx:id="yearCombo" prefWidth="110.0" promptText="Year"
                         style="-fx-font-size: 13px; -fx-cursor: hand;" />

               <Region HBox.hgrow="ALWAYS" />
               <Button mnemonicParsing="false" onAction="#handleGenerateReport"
                       styleClass="primary-btn"
                       style="-fx-font-weight: 700; -fx-padding: 9 22; -fx-font-size: 13px;"
                       text="Generate Reports" />
               <Button mnemonicParsing="false" onAction="#handleGenerateUsageReport"
                       styleClass="secondary-btn"
                       style="-fx-font-weight: 700; -fx-padding: 9 18; -fx-font-size: 13px;"
                       text="Usage Report" />
               <Button mnemonicParsing="false" onAction="#handleSubmitReport"
                       styleClass="gold-btn"
                       style="-fx-font-weight: 700; -fx-padding: 9 18; -fx-font-size: 13px;"
                       text="Submit Report" />
            </HBox>

            <!-- ── CHARTS ROW ─────────────────────────────── -->
            <HBox spacing="18.0">

               <!-- Visitor Pie Chart -->
               <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10.0"
                     style="-fx-border-color: rgba(29,201,138,0.14) rgba(29,201,138,0.14) rgba(29,201,138,0.14) rgba(29,201,138,0.70); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                  <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                  <Label text="Visitor Type Breakdown" styleClass="section-blue"
                         style="-fx-font-size: 13px;" />
                  <PieChart fx:id="visitorPieChart" prefHeight="260.0" animated="false"
                            legendVisible="true" />
               </VBox>

               <!-- Income Bar Chart -->
               <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="10.0"
                     style="-fx-border-color: rgba(232,160,32,0.14) rgba(232,160,32,0.14) rgba(232,160,32,0.14) rgba(232,160,32,0.70); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 10 10 0; -fx-background-radius: 0 10 10 0;">
                  <padding><Insets bottom="16.0" left="18.0" right="18.0" top="16.0" /></padding>
                  <Label text="Monthly Income" styleClass="section-gold"
                         style="-fx-font-size: 13px;" />
                  <BarChart fx:id="incomeBarChart" prefHeight="260.0" animated="false"
                            legendVisible="false">
                     <xAxis><CategoryAxis label="Month" /></xAxis>
                     <yAxis><NumberAxis label="Income (ILS)" /></yAxis>
                  </BarChart>
               </VBox>
            </HBox>

            <!-- ── USAGE LIST ─────────────────────────────── -->
            <VBox styleClass="card" spacing="12.0">
               <padding><Insets bottom="20.0" left="24.0" right="24.0" top="18.0" /></padding>
               <HBox alignment="CENTER_LEFT" spacing="8.0">
                  <Label text="📋" style="-fx-font-size: 15px;" />
                  <Label text="Capacity Usage Details" styleClass="section-blue"
                         style="-fx-font-size: 14px;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblUsageSummary" styleClass="subtitle-label"
                         style="-fx-font-size: 12px;" />
               </HBox>
               <Separator />
               <ListView fx:id="usageList" prefHeight="160.0" />
            </VBox>

            <!-- ── STATUS ─────────────────────────────────── -->
            <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity"
                   wrapText="true" minHeight="24.0"
                   style="-fx-font-size: 13px; -fx-font-weight: 700;" />

         </VBox>
      </content>
   </ScrollPane>
</StackPane>
