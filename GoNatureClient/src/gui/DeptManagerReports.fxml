<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="780.0" prefWidth="860.0" spacing="14.0"
      styleClass="page-root" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.DeptManagerReportsController">
   <padding><Insets bottom="30.0" left="40.0" right="40.0" top="20.0" /></padding>

   <HBox alignment="CENTER_RIGHT">
      <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme"
              styleClass="theme-toggle" text="🌙 Dark Mode" />
   </HBox>

   <HBox alignment="CENTER_LEFT">
      <Button mnemonicParsing="false" onAction="#handleGoBack"
              styleClass="back-link" text="&lt; Back to Dashboard" />
   </HBox>

   <Label styleClass="title-label" text="Department Manager — System Reports">
      <font><Font name="Segoe UI Bold" size="26.0" /></font>
   </Label>

   <!-- ── FILTER ROW ── -->
   <VBox spacing="10.0" styleClass="card" style="-fx-padding: 20;">
      <Label styleClass="section-blue" text="Select Report Parameters">
         <font><Font name="Segoe UI Bold" size="14.0" /></font>
      </Label>
      <HBox spacing="16.0" alignment="CENTER_LEFT">
         <VBox spacing="4.0">
            <Label styleClass="body-label" text="Park:" />
            <ComboBox fx:id="cmbPark" prefWidth="200.0" promptText="Select Park" />
         </VBox>
         <VBox spacing="4.0">
            <Label styleClass="body-label" text="Month:" />
            <ComboBox fx:id="cmbMonth" prefWidth="100.0" promptText="Month" />
         </VBox>
         <VBox spacing="4.0">
            <Label styleClass="body-label" text="Year:" />
            <ComboBox fx:id="cmbYear" prefWidth="100.0" promptText="Year" />
         </VBox>
         <VBox spacing="4.0" alignment="BOTTOM_LEFT">
            <Label text=" " />
            <HBox spacing="10.0">
               <Button mnemonicParsing="false" onAction="#handleViewSubmittedReport"
                       prefHeight="36.0" prefWidth="160.0" styleClass="primary-btn"
                       style="-fx-font-size: 13px;" text="📋 Submitted Report" />
               <Button mnemonicParsing="false" onAction="#handleCancellationsReport"
                       prefHeight="36.0" prefWidth="170.0" styleClass="danger-btn"
                       style="-fx-font-size: 13px;" text="❌ Cancellations Report" />
               <Button mnemonicParsing="false" onAction="#handleVisitReport"
                       prefHeight="36.0" prefWidth="150.0" styleClass="success-btn"
                       style="-fx-font-size: 13px;" text="🕐 Visit Report" />
            </HBox>
         </VBox>
      </HBox>
      <Label fx:id="lblStatus" wrapText="true" prefWidth="750.0"
             style="-fx-font-weight: bold; -fx-font-size: 13px;">
         <VBox.margin><Insets top="4.0" /></VBox.margin>
      </Label>
   </VBox>

   <!-- ── CHARTS AREA ── -->
   <HBox spacing="20.0" alignment="TOP_CENTER">
      <VBox spacing="8.0" alignment="CENTER" prefWidth="380.0" styleClass="card" style="-fx-padding: 16;">
         <Label styleClass="section-blue" text="Visitors by Type">
            <font><Font name="Segoe UI Bold" size="13.0" /></font>
         </Label>
         <PieChart fx:id="visitorPieChart" prefHeight="240.0" prefWidth="360.0"
                   labelsVisible="true" legendVisible="true" />
         <HBox alignment="CENTER" spacing="20.0">
            <Label fx:id="lblTotalVisitors" styleClass="body-label" text="Total: —" />
         </HBox>
      </VBox>

      <VBox spacing="8.0" alignment="CENTER" prefWidth="420.0" styleClass="card" style="-fx-padding: 16;">
         <Label styleClass="section-blue" text="Income / Count by Type">
            <font><Font name="Segoe UI Bold" size="13.0" /></font>
         </Label>
         <BarChart fx:id="incomeBarChart" prefHeight="240.0" prefWidth="400.0">
            <xAxis><CategoryAxis /></xAxis>
            <yAxis><NumberAxis /></yAxis>
         </BarChart>
         <HBox alignment="CENTER" spacing="20.0">
            <Label fx:id="lblTotalIncome" styleClass="body-label" text="Income: —" />
         </HBox>
      </VBox>
   </HBox>

</VBox>
