<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="750.0" prefWidth="680.0" spacing="18.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ParkEntranceController">
   <padding>
      <Insets bottom="30.0" left="50.0" right="50.0" top="20.0" />
   </padding>

   <HBox alignment="CENTER_RIGHT">
      <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
      <VBox.margin><Insets bottom="5.0" /></VBox.margin>
   </HBox>

   <Label styleClass="title-label" text="Park Gate Scanner">
      <font><Font name="Segoe UI Bold" size="30.0" /></font>
   </Label>

   <!-- ── PRE-BOOKED VISITORS CARD ── -->
   <VBox alignment="CENTER" spacing="16.0" styleClass="card" style="-fx-padding: 30;">
      <Label styleClass="section-blue" text="Pre-Booked Visitors">
         <font><Font name="Segoe UI Bold" size="16.0" /></font>
      </Label>
      <Label styleClass="subtitle-label" text="Enter Order ID to validate entry or register exit.">
         <font><Font name="Segoe UI" size="13.0" /></font>
      </Label>

      <TextField fx:id="txtOrderId" alignment="CENTER" prefHeight="48.0" prefWidth="280.0"
                 promptText="Order ID" style="-fx-font-size: 18px;">
         <VBox.margin><Insets left="80.0" right="80.0" /></VBox.margin>
      </TextField>

      <HBox alignment="CENTER" spacing="20.0">
         <Button fx:id="btnAdmit" mnemonicParsing="false" onAction="#handleAdmit"
                 prefHeight="44.0" prefWidth="155.0" styleClass="success-btn"
                 style="-fx-font-size: 14px;" text="✔ Validate &amp; Admit" />
         <Button fx:id="btnExit" mnemonicParsing="false" onAction="#handleExit"
                 prefHeight="44.0" prefWidth="155.0" styleClass="danger-btn"
                 style="-fx-font-size: 14px;" text="✖ Register Exit" />
      </HBox>

      <Label fx:id="lblStatus" alignment="CENTER" prefWidth="500.0" wrapText="true">
         <font><Font name="Segoe UI Bold" size="14.0" /></font>
         <VBox.margin><Insets top="4.0" /></VBox.margin>
      </Label>
   </VBox>

   <!-- ── WALK-IN VISITORS CARD ── -->
   <VBox alignment="CENTER" spacing="16.0" styleClass="card" style="-fx-padding: 30;">
      <Label styleClass="section-blue" text="Walk-in Visitors (No Booking)">
         <font><Font name="Segoe UI Bold" size="16.0" /></font>
      </Label>
      <Label styleClass="subtitle-label" text="Admit casual visitors if the park has available capacity.">
         <font><Font name="Segoe UI" size="13.0" /></font>
      </Label>

      <HBox alignment="CENTER" spacing="20.0">
         <VBox spacing="6.0" alignment="CENTER_LEFT">
            <Label styleClass="body-label" text="Visitor Count:">
               <font><Font name="Segoe UI Bold" size="13.0" /></font>
            </Label>
            <TextField fx:id="txtWalkInCount" prefHeight="40.0" prefWidth="130.0"
                       promptText="e.g. 3" style="-fx-font-size: 15px;" />
         </VBox>
         <VBox spacing="6.0" alignment="CENTER_LEFT">
            <Label styleClass="body-label" text="Visit Type:">
               <font><Font name="Segoe UI Bold" size="13.0" /></font>
            </Label>
            <ComboBox fx:id="cmbWalkInType" prefWidth="160.0" promptText="Select type" />
         </VBox>
      </HBox>

      <Button fx:id="btnWalkIn" mnemonicParsing="false" onAction="#handleWalkIn"
              prefHeight="44.0" prefWidth="220.0" styleClass="primary-btn"
              style="-fx-font-size: 14px;" text="Process Walk-in" />

      <Label fx:id="lblWalkInStatus" alignment="CENTER" prefWidth="500.0" wrapText="true">
         <font><Font name="Segoe UI Bold" size="14.0" /></font>
         <VBox.margin><Insets top="4.0" /></VBox.margin>
      </Label>
   </VBox>
</VBox>