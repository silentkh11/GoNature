<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="650.0" spacing="25.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ParkEntranceController">
   <padding>
      <Insets bottom="40.0" left="50.0" right="50.0" top="20.0" />
   </padding>

   <HBox alignment="CENTER_RIGHT">
      <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
      <VBox.margin><Insets bottom="5.0" /></VBox.margin>
   </HBox>

   <Label styleClass="title-label" text="Park Gate Scanner">
      <font><Font name="Segoe UI Bold" size="32.0" /></font>
   </Label>

   <Label styleClass="subtitle-label" text="Enter the visitor's Order ID to validate entry.">
      <font><Font name="Segoe UI" size="16.0" /></font>
   </Label>

   <VBox alignment="CENTER" spacing="20.0" styleClass="card" style="-fx-padding: 40; -fx-background-radius: 10; -fx-border-radius: 10;">

      <Label styleClass="body-label" text="Scan / Enter Order ID:">
         <font><Font name="Segoe UI Bold" size="18.0" /></font>
      </Label>

      <TextField fx:id="txtOrderId" alignment="CENTER" prefHeight="50.0" prefWidth="300.0" promptText="e.g. 1" style="-fx-font-size: 20px; -fx-background-radius: 8; -fx-border-radius: 8;">
         <VBox.margin>
            <Insets left="50.0" right="50.0" />
         </VBox.margin>
      </TextField>

      <Button fx:id="btnAdmit" mnemonicParsing="false" onAction="#handleAdmit" prefHeight="45.0" prefWidth="200.0" styleClass="success-btn" style="-fx-font-size: 16px; -fx-background-radius: 8;" text="Validate &amp; Admit" />

      <Label fx:id="lblStatus" alignment="CENTER" contentDisplay="CENTER" prefHeight="60.0" prefWidth="400.0" textAlignment="CENTER" wrapText="true">
         <font><Font name="Segoe UI Bold" size="16.0" /></font>
         <VBox.margin><Insets top="10.0" /></VBox.margin>
      </Label>
   </VBox>
</VBox>
