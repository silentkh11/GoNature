<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="680.0" prefWidth="860.0" styleClass="page-root"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.auth.RegisterController">

   <top>
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <padding><Insets left="24.0" right="24.0" top="18.0" bottom="10.0" /></padding>
         <Button mnemonicParsing="false" onAction="#handleGoBack"
                 styleClass="back-link" text="← Back to Main Menu" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme"
                 styleClass="theme-toggle" text="☀ Light Mode" />
      </HBox>
   </top>

   <center>
      <VBox alignment="CENTER" maxWidth="580.0" spacing="0" BorderPane.alignment="CENTER">
         <BorderPane.margin><Insets bottom="30.0" /></BorderPane.margin>

         <!-- Header -->
         <HBox alignment="CENTER_LEFT" spacing="14.0">
            <VBox.margin><Insets bottom="18.0" /></VBox.margin>
            <Label text="🌱" style="-fx-font-size: 28px;" />
            <VBox spacing="2.0">
               <Label text="Create Your Account" styleClass="title-label"
                      style="-fx-font-size: 24px; -fx-font-weight: bold;" />
               <Label text="Join GoNature as a subscriber and enjoy pre-booked visits"
                      styleClass="subtitle-label" style="-fx-font-size: 13px;" />
            </VBox>
         </HBox>

         <!-- Form Card -->
         <VBox styleClass="card" spacing="0"
               style="-fx-border-color: rgba(76,158,232,0.14) rgba(76,158,232,0.14) rgba(76,158,232,0.14) rgba(29,201,138,0.60); -fx-border-width: 1 1 1 3; -fx-border-radius: 0 14 14 0; -fx-background-radius: 0 14 14 0;">
            <padding><Insets bottom="28.0" left="30.0" right="30.0" top="26.0" /></padding>

            <Label text="Personal Information" styleClass="section-blue"
                   style="-fx-font-size: 13px;">
               <VBox.margin><Insets bottom="14.0" /></VBox.margin>
            </Label>

            <GridPane hgap="18.0" vgap="14.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="120.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="110.0" prefWidth="120.0" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>

               <Label styleClass="body-label" text="ID Number"
                      style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.columnIndex="0" GridPane.rowIndex="0" />
               <TextField fx:id="txtId" promptText="Your ID number"
                          GridPane.columnIndex="1" GridPane.rowIndex="0" />

               <Label styleClass="body-label" text="Email"
                      style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.columnIndex="2" GridPane.rowIndex="0" />
               <TextField fx:id="txtEmail" promptText="example@mail.com"
                          GridPane.columnIndex="3" GridPane.rowIndex="0" />

               <Label styleClass="body-label" text="First Name"
                      style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.columnIndex="0" GridPane.rowIndex="1" />
               <TextField fx:id="txtFirst" promptText="First name"
                          GridPane.columnIndex="1" GridPane.rowIndex="1" />

               <Label styleClass="body-label" text="Last Name"
                      style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.columnIndex="2" GridPane.rowIndex="1" />
               <TextField fx:id="txtLast" promptText="Last name"
                          GridPane.columnIndex="3" GridPane.rowIndex="1" />

               <Label styleClass="body-label" text="Phone"
                      style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.columnIndex="0" GridPane.rowIndex="2" />
               <TextField fx:id="txtPhone" promptText="05X-XXXXXXX"
                          GridPane.columnIndex="1" GridPane.rowIndex="2" />

               <Label styleClass="body-label" text="Credit Card"
                      style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.columnIndex="2" GridPane.rowIndex="2" />
               <TextField fx:id="txtCard" promptText="Optional"
                          GridPane.columnIndex="3" GridPane.rowIndex="2" />

               <Label styleClass="body-label" text="Family Size"
                      style="-fx-font-weight: bold; -fx-font-size: 12px;"
                      GridPane.columnIndex="0" GridPane.rowIndex="3" />
               <TextField fx:id="txtFamilySize" promptText="Default: 1"
                          GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </GridPane>

            <Separator style="-fx-opacity: 0.6;">
               <VBox.margin><Insets top="20.0" bottom="16.0" /></VBox.margin>
            </Separator>

            <CheckBox fx:id="chkGuide" mnemonicParsing="false"
                      text="I am a Certified Tour Guide  🏕️">
               <font><Font name="Segoe UI" size="13.0" /></font>
               <VBox.margin><Insets bottom="16.0" /></VBox.margin>
            </CheckBox>

            <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity"
                   wrapText="true" style="-fx-font-size: 12px;">
               <VBox.margin><Insets bottom="4.0" /></VBox.margin>
            </Label>

            <Button fx:id="btnRegister" maxWidth="Infinity" mnemonicParsing="false"
                    onAction="#handleRegister" prefHeight="44.0"
                    styleClass="primary-btn" style="-fx-font-size: 15px;"
                    text="Create Account" />
         </VBox>
      </VBox>
   </center>
</BorderPane>
