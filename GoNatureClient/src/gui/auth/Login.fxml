<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="850.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.auth.LoginController">

   <top>
      <BorderPane BorderPane.alignment="CENTER">
         <padding><Insets left="20.0" right="20.0" top="15.0" bottom="5.0" /></padding>
         <left>
            <Button focusTraversable="false" mnemonicParsing="false" onAction="#handleGoBack" styleClass="back-link" text="&lt; Back to Main Menu" />
         </left>
         <right>
            <Button fx:id="themeBtn" focusTraversable="false" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
         </right>
      </BorderPane>
   </top>

   <center>
      <VBox alignment="CENTER" maxWidth="400.0" maxHeight="450.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" maxWidth="Infinity" text="🏕️">
               <font><Font size="42.0" /></font>
            </Label>

            <Label styleClass="title-label" text="GoNature Portal">
               <font>
                  <Font name="Segoe UI Bold" size="26.0" />
               </font>
            </Label>

            <VBox spacing="15.0" styleClass="card" style="-fx-padding: 25;">
               <VBox spacing="5.0">
                  <Label styleClass="body-label" text="Username">
                     <font><Font name="Segoe UI Bold" size="14.0" /></font>
                  </Label>
                  <TextField fx:id="usernameField" onAction="#handleLogin" promptText="Enter username..." style="-fx-padding: 10; -fx-font-size: 14px;" />
               </VBox>

               <VBox spacing="5.0">
                  <Label styleClass="body-label" text="Password">
                     <font><Font name="Segoe UI Bold" size="14.0" /></font>
                  </Label>
                  <PasswordField fx:id="passwordField" onAction="#handleLogin" promptText="Enter password..." style="-fx-padding: 10; -fx-font-size: 14px;" />
               </VBox>

               <Label fx:id="errorLabel" style="-fx-text-fill: #E83A5A; -fx-font-weight: bold;" text="Error message here" visible="false" wrapText="true" />

               <Button fx:id="loginBtn" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" styleClass="primary-btn" style="-fx-font-size: 15px; -fx-padding: 12;" text="Login">
                  <VBox.margin><Insets top="10.0" /></VBox.margin>
               </Button>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets bottom="50.0" />
         </BorderPane.margin>
      </VBox>
   </center>
</BorderPane>
