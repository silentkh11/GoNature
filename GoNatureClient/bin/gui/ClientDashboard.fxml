<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ClientDashboardController">
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>

   <Label style="-fx-text-fill: #2c3e50;" text="Order Management Dashboard">
      <font>
         <Font name="Segoe UI Bold" size="24.0" />
      </font>
   </Label>

   <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <Label text="Server Connection">
         <font>
            <Font name="Segoe UI Bold" size="14.0" />
         </font>
      </Label>
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <Label style="-fx-font-weight: bold; -fx-text-fill: #2d3436;" text="IP Address:" />
         <TextField fx:id="ipField" prefWidth="150.0" promptText="Server IP" text="localhost" disable="true" />
         <Label style="-fx-font-weight: bold; -fx-text-fill: #2d3436;" text="Port:" />
         <TextField fx:id="portField" prefWidth="100.0" promptText="Port" text="5555" disable="true" />
      </HBox>
   </VBox>

   <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" VBox.vgrow="ALWAYS">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <Label text="Active Orders">
         <font>
            <Font name="Segoe UI Bold" size="14.0" />
         </font>
      </Label>
      <TableView fx:id="table" style="-fx-font-size: 14px; -fx-base: #f1f2f6;" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="numCol" prefWidth="200.0" style="-fx-alignment: CENTER;" text="Order Number" />
          <TableColumn fx:id="dateCol" prefWidth="250.0" style="-fx-alignment: CENTER;" text="Order Date" />
            <TableColumn fx:id="visitorsCol" prefWidth="200.0" style="-fx-alignment: CENTER;" text="Visitors" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </VBox>

   <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dcdde1; -fx-border-radius: 8; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <Label text="Update Selected Order">
         <font>
            <Font name="Segoe UI Bold" size="14.0" />
         </font>
      </Label>
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <Label style="-fx-font-weight: bold; -fx-text-fill: #2d3436;" text="New Date:" />
         <DatePicker fx:id="datePicker" prefWidth="150.0" promptText="Select Date" />
         <Label style="-fx-font-weight: bold; -fx-text-fill: #2d3436;" text="New Visitors:" />
         <Spinner fx:id="visitorSpinner" editable="true" prefWidth="120.0" />
         <Button fx:id="updateBtn" disable="true" mnemonicParsing="false" onAction="#updateSelectedOrder" style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 5; -fx-cursor: hand;" text="Confirm Update" />
      </HBox>
      <Label fx:id="statusMsg" style="-fx-text-fill: #0984e3; -fx-font-style: italic;" text="Ready to connect." />
   </VBox>
</VBox>