<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="850.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.RegisterController">

   <top>
      <BorderPane BorderPane.alignment="CENTER">
         <padding><Insets left="20.0" right="20.0" top="15.0" bottom="5.0" /></padding>
         <left>
            <Button mnemonicParsing="false" onAction="#handleGoBack" styleClass="back-link" text="&lt; Back to Main Menu" />
         </left>
         <right>
            <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
         </right>
      </BorderPane>
   </top>

   <center>
      <VBox alignment="CENTER" maxWidth="500.0" spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="title-label" text="Become a GoNature Subscriber">
               <font><Font name="Segoe UI Bold" size="24.0" /></font>
            </Label>

            <VBox spacing="15.0" styleClass="card" style="-fx-padding: 30;">
               <GridPane hgap="15.0" vgap="15.0">
                  <Label styleClass="body-label" text="ID Number:" GridPane.columnIndex="0" GridPane.rowIndex="0"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtId" promptText="Your ID" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                  <Label styleClass="body-label" text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtFirst" promptText="First Name" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                  <Label styleClass="body-label" text="Last Name:" GridPane.columnIndex="0" GridPane.rowIndex="2"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtLast" promptText="Last Name" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                  <Label styleClass="body-label" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="3"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtEmail" promptText="example@mail.com" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                  <Label styleClass="body-label" text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="4"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtPhone" promptText="05X-XXXXXXX" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                  <Label styleClass="body-label" text="Credit Card:" GridPane.columnIndex="0" GridPane.rowIndex="5"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtCard" promptText="Optional" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                  <Label styleClass="body-label" text="Family Size:" GridPane.columnIndex="0" GridPane.rowIndex="6"><font><Font name="Segoe UI Bold" size="14.0" /></font></Label>
                  <TextField fx:id="txtFamilySize" promptText="Default: 1" GridPane.columnIndex="1" GridPane.rowIndex="6" />
               </GridPane>

               <CheckBox fx:id="chkGuide" mnemonicParsing="false" text="I am a Certified Tour Guide">
                  <font><Font name="Segoe UI Bold" size="14.0" /></font>
                  <VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin>
               </CheckBox>

               <Label fx:id="lblStatus" alignment="CENTER" maxWidth="Infinity" wrapText="true" />

               <Button fx:id="btnRegister" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleRegister" prefHeight="40.0" styleClass="primary-btn" style="-fx-font-size: 15px;" text="Create Account" />
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets bottom="40.0" />
         </BorderPane.margin>
      </VBox>
   </center>
</BorderPane>
