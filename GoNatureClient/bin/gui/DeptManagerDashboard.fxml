<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" styleClass="page-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.DeptManagerController">
   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="20.0" />
   </padding>

   <HBox alignment="CENTER_RIGHT">
      <Button fx:id="themeBtn" mnemonicParsing="false" onAction="#handleToggleTheme" styleClass="theme-toggle" text="🌙 Dark Mode" />
      <VBox.margin><Insets bottom="5.0" /></VBox.margin>
   </HBox>

   <Label styleClass="title-label" text="Department Manager Dashboard">
      <font><Font name="Segoe UI Bold" size="28.0" /></font>
   </Label>

   <Label styleClass="subtitle-label" text="Review pending park parameter changes. Select a row to take action.">
      <font><Font name="Segoe UI" size="14.0" /></font>
   </Label>

   <TableView fx:id="requestsTable" prefHeight="350.0" prefWidth="720.0">
     <columns>
       <TableColumn fx:id="colReqId" prefWidth="70.0" text="Req ID" />
       <TableColumn fx:id="colPark" prefWidth="200.0" text="Park Name" />
       <TableColumn fx:id="colCapacity" prefWidth="150.0" text="New Max Capacity" />
       <TableColumn fx:id="colGap" prefWidth="150.0" text="New Casual Gap" />
       <TableColumn fx:id="colTime" prefWidth="145.0" text="New Stay Time (Hrs)" />
     </columns>
   </TableView>

   <HBox alignment="CENTER" spacing="30.0">
      <children>
         <Button fx:id="btnApprove" mnemonicParsing="false" onAction="#handleApprove" prefHeight="45.0" prefWidth="150.0" styleClass="success-btn" style="-fx-font-size: 14px;" text="✔ Approve Request" />
         <Button fx:id="btnDeny" mnemonicParsing="false" onAction="#handleDeny" prefHeight="45.0" prefWidth="150.0" styleClass="danger-btn" style="-fx-font-size: 14px;" text="✖ Deny Request" />
      </children>
      <VBox.margin><Insets top="10.0" /></VBox.margin>
   </HBox>

   <Label fx:id="lblStatus" alignment="CENTER" prefWidth="600.0" style="-fx-font-weight: bold; -fx-font-size: 14px;">
      <VBox.margin><Insets top="10.0" /></VBox.margin>
   </Label>
</VBox>
